<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Library</title>
  <script crossorigin src="https://unpkg.com/react@18/umd/react.development.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body, #root { height: 100%; }
    body { background: #08080f; color: #f5f5ff; font-family: 'Segoe UI', system-ui, sans-serif; }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #0f0f1a; }
    ::-webkit-scrollbar-thumb { background: #2a2a4a; border-radius: 3px; }
    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .fade-in { animation: fadeIn 0.35s ease forwards; }
    .spinner { width: 20px; height: 20px; border: 2px solid #2a2a4a; border-top-color: #7c6ef7; border-radius: 50%; animation: spin 0.7s linear infinite; }
    input:focus { border-color: #7c6ef7 !important; }
    button:hover:not(:disabled) { filter: brightness(1.12); }
    button:active:not(:disabled) { transform: scale(0.98); }
    .suggestion-item:hover { background: #14142a !important; }
    .book-tile { transition: transform 0.18s; }
    .book-tile:hover { transform: translateY(-4px); }
    .book-tile-overlay { transition: opacity 0.2s; }
    .book-tile-remove  { transition: opacity 0.15s; }
    .book-tile-edit    { transition: opacity 0.15s; }
    .book-tile:hover .book-tile-overlay { opacity: 1 !important; }
    .book-tile:hover .book-tile-remove  { opacity: 1 !important; }
    .book-tile:hover .book-tile-edit    { opacity: 1 !important; }
    textarea:focus { border-color: #7c6ef7 !important; }
    .tab-btn { flex:1; padding:8px; border:none; border-radius:7px; cursor:pointer; font-size:13px; font-weight:600; transition:background 0.15s,color 0.15s; }
  </style>
</head>
<body>
  <div id="root"></div>
  <script type="text/babel">
    const { useState, useEffect, useRef, useCallback } = React;

    const C = {
      bg: '#08080f', surface: '#0f0f1a', surface2: '#14142a',
      border: '#1e1e3a', accent: '#7c6ef7', text: '#f5f5ff',
      muted: '#7777aa', gold: '#f5c518', green: '#3de8a0',
      purple: '#c084fc', error: '#f56565',
    };

    function debounce(fn, ms) {
      let t;
      return (...args) => { clearTimeout(t); t = setTimeout(() => fn(...args), ms); };
    }

    async function callAI(apiKey, title, authors, description) {
      const prompt = `You are an expert book analyst creating a permanent reference summary for someone who wants to deeply understand and revisit "${title}" by ${authors} at any time.${description ? `\n\nPublisher description: ${description}` : ''}

Return ONLY a valid JSON object with no extra text, no markdown, no code fences:
{
  "summary": "A rich 3-4 paragraph overview covering the book's central thesis, why it was written, the core framework or argument, and its lasting significance.",
  "goldenTips": ["A fully explained tip — not just a label but a complete insight with context and why it matters", "tip 2", "tip 3", "tip 4", "tip 5", "tip 6", "tip 7"],
  "realLife": ["A concrete, specific action someone can apply today — describe the situation, what to do, and the expected outcome", "takeaway 2", "takeaway 3", "takeaway 4", "takeaway 5", "takeaway 6"],
  "chapters": [
    {
      "title": "Chapter 1: Full Chapter Title",
      "summary": "A thorough 4-6 paragraph summary of this chapter. Cover: the main argument or story of the chapter, the key concepts and how they are explained, any examples, anecdotes or case studies the author uses, the most important insights and why they matter, and how this chapter connects to the book's overall message. Write it so someone who reads only this summary fully understands what the chapter teaches."
    }
  ]
}

Rules:
- Every chapter summary must be 4-6 substantial paragraphs — never a single sentence or short paragraph.
- List every chapter in the correct order with accurate titles.
- Golden tips must be complete thoughts, not labels (e.g. not just "Be proactive" but a full explanation of what that means and why).
- Real life takeaways must be specific and actionable with a clear outcome described.
- Write as if this reference will be read years from now by someone who has forgotten the book.`;

      const res = await fetch('https://api.groq.com/openai/v1/chat/completions', {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${apiKey}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          model: 'llama-3.3-70b-versatile',
          messages: [{ role: 'user', content: prompt }],
          max_tokens: 32768,
          temperature: 0.7,
        }),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.error?.message || `API error ${res.status}`);
      }

      const data = await res.json();
      let text = data.choices[0].message.content.trim();
      text = text.replace(/^```(?:json)?\s*/i, '').replace(/\s*```$/, '');
      try {
        return JSON.parse(text);
      } catch {
        // Truncated JSON — find last complete chapter entry and close the structure
        const summaryMatch = text.match(/"summary"\s*:\s*"([\s\S]*?)"\s*,\s*"goldenTips"/);
        const tipsMatch = text.match(/"goldenTips"\s*:\s*(\[[\s\S]*?\])\s*,\s*"realLife"/);
        const realMatch = text.match(/"realLife"\s*:\s*(\[[\s\S]*?\])\s*,\s*"chapters"/);
        const chaptersStart = text.indexOf('"chapters"');
        if (chaptersStart === -1) throw new Error('AI returned malformed JSON — please try again');
        // Find last fully closed chapter object
        let chaptersStr = text.slice(chaptersStart + '"chapters"'.length).replace(/^\s*:\s*/, '');
        const lastClose = chaptersStr.lastIndexOf('}');
        if (lastClose !== -1) chaptersStr = chaptersStr.slice(0, lastClose + 1) + ']';
        let chapters = [];
        try { chapters = JSON.parse(chaptersStr); } catch {}
        return {
          summary: summaryMatch ? summaryMatch[1].replace(/\\n/g, '\n') : '',
          goldenTips: tipsMatch ? JSON.parse(tipsMatch[1]) : [],
          realLife: realMatch ? JSON.parse(realMatch[1]) : [],
          chapters,
        };
      }
    }

    // ── Settings Modal ──────────────────────────────────────────────────────────
    function SettingsModal({ apiKey, onSave, onClose }) {
      const [val, setVal] = useState(apiKey || '');
      const save = () => { onSave(val.trim()); onClose(); };
      return (
        <div style={{position:'fixed',inset:0,background:'rgba(0,0,0,0.75)',display:'flex',alignItems:'center',justifyContent:'center',zIndex:200}} onClick={onClose}>
          <div style={{background:C.surface,border:`1px solid ${C.border}`,borderRadius:18,padding:36,width:480,maxWidth:'90vw'}} onClick={e=>e.stopPropagation()}>
            <h2 style={{marginBottom:8,fontSize:20,fontWeight:700}}>Settings</h2>
            <p style={{color:C.muted,fontSize:14,marginBottom:28,lineHeight:1.6}}>Paste your Groq API key for free AI book analysis. 14,400 requests/day free — no credit card needed.</p>
            <label style={{fontSize:12,color:C.muted,display:'block',marginBottom:8,textTransform:'uppercase',letterSpacing:1}}>Groq API Key</label>
            <input
              type="password" value={val} onChange={e=>setVal(e.target.value)}
              onKeyDown={e=>e.key==='Enter'&&save()}
              placeholder="gsk_..."
              autoFocus
              style={{width:'100%',background:C.surface2,border:`1px solid ${C.border}`,borderRadius:10,padding:'13px 15px',color:C.text,fontSize:14,outline:'none',transition:'border-color 0.2s'}}
            />
            <p style={{fontSize:12,color:C.muted,marginTop:8}}>
              Free key at <span style={{color:C.accent}}>console.groq.com</span> — no credit card needed
            </p>
            <div style={{display:'flex',gap:12,marginTop:28}}>
              <button onClick={save} style={{flex:1,padding:'13px',background:C.accent,border:'none',borderRadius:10,color:'#fff',fontWeight:700,cursor:'pointer',fontSize:15,transition:'filter 0.15s'}}>
                Save Key
              </button>
              <button onClick={onClose} style={{padding:'13px 22px',background:'transparent',border:`1px solid ${C.border}`,borderRadius:10,color:C.muted,cursor:'pointer',fontSize:15}}>
                Cancel
              </button>
            </div>
          </div>
        </div>
      );
    }

    // ── Book Card ────────────────────────────────────────────────────────────────
    function BookCard({ book }) {
      const v = book.volumeInfo;
      const cover = v.imageLinks?.thumbnail?.replace('http:', 'https:') || v.imageLinks?.smallThumbnail?.replace('http:', 'https:');
      return (
        <div style={{display:'flex',gap:22,padding:24,background:C.surface,border:`1px solid ${C.border}`,borderRadius:16}}>
          {cover
            ? <img src={cover} alt={v.title} style={{width:88,height:130,objectFit:'cover',borderRadius:8,flexShrink:0,boxShadow:'0 4px 20px rgba(0,0,0,0.5)'}} />
            : <div style={{width:88,height:130,background:C.surface2,borderRadius:8,display:'flex',alignItems:'center',justifyContent:'center',color:C.muted,fontSize:11,flexShrink:0}}>No Cover</div>
          }
          <div style={{flex:1,minWidth:0}}>
            <h2 style={{fontSize:21,fontWeight:800,lineHeight:1.3,marginBottom:6}}>{v.title}</h2>
            {v.subtitle && <p style={{color:C.muted,fontSize:14,marginBottom:10,lineHeight:1.4}}>{v.subtitle}</p>}
            <p style={{color:C.accent,fontSize:14,fontWeight:600,marginBottom:14}}>{(v.authors||['Unknown Author']).join(', ')}</p>
            <div style={{display:'flex',gap:8,flexWrap:'wrap'}}>
              {v.pageCount && <Tag>{v.pageCount} pages</Tag>}
              {v.publishedDate && <Tag>{v.publishedDate.slice(0,4)}</Tag>}
              {v.categories && v.categories[0] && <Tag>{v.categories[0]}</Tag>}
            </div>
          </div>
        </div>
      );
    }

    function Tag({ children }) {
      return <span style={{fontSize:12,color:C.muted,background:C.surface2,padding:'4px 10px',borderRadius:20,border:`1px solid ${C.border}`}}>{children}</span>;
    }

    // ── Book Cover Tile ───────────────────────────────────────────────────────────
    function BookCoverTile({ book, onSelect, onRemove, onEdit }) {
      const v = book.volumeInfo;
      const cover = v.imageLinks?.thumbnail?.replace('http:', 'https:');
      const authorStr = (v.authors || []).join(', ');
      const hues = [240, 260, 280, 300, 200, 220];
      const hue = hues[(v.title.charCodeAt(0) || 0) % hues.length];
      const btnBase = {width:24,height:24,borderRadius:'50%',border:'none',display:'flex',alignItems:'center',justifyContent:'center',cursor:'pointer',opacity:0,padding:0,lineHeight:1,position:'absolute',top:6};
      return (
        <div
          className="book-tile"
          onClick={() => onSelect(book)}
          style={{position:'relative',width:'100%',paddingTop:'150%',borderRadius:10,overflow:'hidden',cursor:'pointer',boxShadow:'0 4px 20px rgba(0,0,0,0.45)'}}
        >
          <div style={{position:'absolute',inset:0}}>
            {cover
              ? <img src={cover} alt={v.title} style={{width:'100%',height:'100%',objectFit:'cover'}} />
              : <div style={{width:'100%',height:'100%',background:`linear-gradient(135deg, hsl(${hue},38%,14%) 0%, hsl(${hue},48%,26%) 100%)`,display:'flex',alignItems:'center',justifyContent:'center',padding:12}}>
                  <span style={{color:'rgba(255,255,255,0.88)',fontSize:13,fontWeight:700,textAlign:'center',lineHeight:1.4}}>{v.title}</span>
                </div>
            }
          </div>
          <div className="book-tile-overlay" style={{position:'absolute',inset:0,background:'rgba(8,8,15,0.82)',display:'flex',flexDirection:'column',alignItems:'center',justifyContent:'center',padding:12,opacity:0}}>
            <span style={{color:C.text,fontSize:13,fontWeight:700,textAlign:'center',lineHeight:1.4,marginBottom:6}}>{v.title}</span>
            {authorStr && <span style={{color:C.muted,fontSize:11,textAlign:'center'}}>{authorStr}</span>}
            {book.analysis && <span style={{color:C.green,fontSize:10,marginTop:6,fontWeight:600}}>Analysis saved</span>}
          </div>
          <button className="book-tile-edit" onClick={e=>{e.stopPropagation();onEdit(book);}}
            style={{...btnBase,left:6,background:'rgba(124,110,247,0.92)',color:'#fff',fontSize:11}}>
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
          </button>
          <button className="book-tile-remove" onClick={e=>{e.stopPropagation();onRemove(book.id);}}
            style={{...btnBase,right:6,background:'rgba(245,101,101,0.92)',color:'#fff',fontSize:14,fontWeight:700}}>×</button>
        </div>
      );
    }

    // ── Library Grid ──────────────────────────────────────────────────────────────
    function LibraryGrid({ books, onSelect, onRemove, onEdit, onAddClick }) {
      return (
        <div style={{marginBottom:40}}>
          <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:20}}>
            <h2 style={{fontSize:18,fontWeight:700,color:C.text}}>My Library</h2>
            <button
              onClick={onAddClick}
              style={{display:'flex',alignItems:'center',gap:6,padding:'8px 16px',background:C.accent,border:'none',borderRadius:10,color:'#fff',fontWeight:700,fontSize:14,cursor:'pointer',transition:'filter 0.15s'}}
            >
              <span style={{fontSize:18,lineHeight:1,marginTop:-1}}>+</span> Add Book
            </button>
          </div>
          {books.length === 0
            ? <div style={{textAlign:'center',padding:'48px 24px',border:`1px dashed ${C.border}`,borderRadius:16,color:C.muted}}>
                <p style={{fontSize:15,marginBottom:6}}>Your library is empty</p>
                <p style={{fontSize:13}}>Search for books above or click "Add Book" to add one manually.</p>
              </div>
            : <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill, minmax(140px, 1fr))',gap:18}}>
                {books.map(b => (
                  <BookCoverTile key={b.id} book={b} onSelect={onSelect} onRemove={onRemove} onEdit={onEdit} />
                ))}
              </div>
          }
        </div>
      );
    }

    // ── Add Book Modal ────────────────────────────────────────────────────────────
    function AddBookModal({ onSave, onClose }) {
      const [title, setTitle] = useState('');
      const [author, setAuthor] = useState('');
      const [coverUrl, setCoverUrl] = useState('');
      const [year, setYear] = useState('');
      const [description, setDescription] = useState('');
      const [errors, setErrors] = useState({});

      const inputStyle = {width:'100%',background:C.surface2,border:`1px solid ${C.border}`,borderRadius:10,padding:'12px 14px',color:C.text,fontSize:14,outline:'none',transition:'border-color 0.2s'};
      const labelStyle = {fontSize:12,color:C.muted,display:'block',marginBottom:6,textTransform:'uppercase',letterSpacing:0.8};
      const fieldStyle = {marginBottom:18};

      const validate = () => {
        const e = {};
        if (!title.trim()) e.title = 'Title is required';
        if (!author.trim()) e.author = 'Author is required';
        if (year.trim() && !/^\d{4}$/.test(year.trim())) e.year = 'Enter a valid 4-digit year';
        if (coverUrl.trim() && !coverUrl.trim().startsWith('http')) e.coverUrl = 'Enter a valid URL starting with http';
        return e;
      };

      const save = () => {
        const e = validate();
        if (Object.keys(e).length > 0) { setErrors(e); return; }
        onSave({ title, author, coverUrl, year, description });
      };

      return (
        <div style={{position:'fixed',inset:0,background:'rgba(0,0,0,0.75)',display:'flex',alignItems:'center',justifyContent:'center',zIndex:200}} onClick={onClose}>
          <div style={{background:C.surface,border:`1px solid ${C.border}`,borderRadius:18,padding:36,width:520,maxWidth:'92vw',maxHeight:'90vh',overflowY:'auto'}} onClick={e=>e.stopPropagation()}>
            <h2 style={{marginBottom:6,fontSize:20,fontWeight:700}}>Add Book</h2>
            <p style={{color:C.muted,fontSize:13,marginBottom:28}}>Add a book manually to your library.</p>

            <div style={fieldStyle}>
              <label style={labelStyle}>Title *</label>
              <input value={title} onChange={e=>{setTitle(e.target.value);setErrors(v=>({...v,title:''}));}} onKeyDown={e=>e.key==='Enter'&&save()} placeholder="e.g. The 48 Laws of Power" autoFocus style={inputStyle} />
              {errors.title && <p style={{color:C.error,fontSize:12,marginTop:4}}>{errors.title}</p>}
            </div>

            <div style={fieldStyle}>
              <label style={labelStyle}>Author *</label>
              <input value={author} onChange={e=>{setAuthor(e.target.value);setErrors(v=>({...v,author:''}));}} onKeyDown={e=>e.key==='Enter'&&save()} placeholder="e.g. Robert Greene" style={inputStyle} />
              {errors.author && <p style={{color:C.error,fontSize:12,marginTop:4}}>{errors.author}</p>}
            </div>

            <div style={fieldStyle}>
              <label style={labelStyle}>Cover Image URL</label>
              <input value={coverUrl} onChange={e=>{setCoverUrl(e.target.value);setErrors(v=>({...v,coverUrl:''}));}} placeholder="https://..." style={inputStyle} />
              {errors.coverUrl && <p style={{color:C.error,fontSize:12,marginTop:4}}>{errors.coverUrl}</p>}
            </div>

            <div style={fieldStyle}>
              <label style={labelStyle}>Year</label>
              <input value={year} onChange={e=>{setYear(e.target.value);setErrors(v=>({...v,year:''}));}} placeholder="e.g. 1998" style={inputStyle} />
              {errors.year && <p style={{color:C.error,fontSize:12,marginTop:4}}>{errors.year}</p>}
            </div>

            <div style={fieldStyle}>
              <label style={labelStyle}>Description</label>
              <textarea value={description} onChange={e=>setDescription(e.target.value)} placeholder="Brief description (optional)..." rows={3} style={{...inputStyle,resize:'vertical',fontFamily:'inherit',lineHeight:1.6}} />
            </div>

            <div style={{display:'flex',gap:12,marginTop:8}}>
              <button onClick={save} style={{flex:1,padding:'13px',background:C.accent,border:'none',borderRadius:10,color:'#fff',fontWeight:700,cursor:'pointer',fontSize:15,transition:'filter 0.15s'}}>Add to Library</button>
              <button onClick={onClose} style={{padding:'13px 22px',background:'transparent',border:`1px solid ${C.border}`,borderRadius:10,color:C.muted,cursor:'pointer',fontSize:15}}>Cancel</button>
            </div>
          </div>
        </div>
      );
    }

    // ── Edit Book Modal ───────────────────────────────────────────────────────────
    function EditBookModal({ book, onSave, onClose }) {
      const v = book.volumeInfo;
      const a = book.analysis || {};
      const [tab, setTab] = useState('details');
      const [title, setTitle] = useState(v.title || '');
      const [author, setAuthor] = useState((v.authors || []).join(', '));
      const [coverUrl, setCoverUrl] = useState(v.imageLinks?.thumbnail || '');
      const [year, setYear] = useState(v.publishedDate || '');
      const [description, setDescription] = useState(v.description || '');
      const [summary, setSummary] = useState(a.summary || '');
      const [tipsText, setTipsText] = useState((a.goldenTips || []).join('\n'));
      const [realLifeText, setRealLifeText] = useState((a.realLife || []).join('\n'));
      const [chapters, setChapters] = useState(a.chapters ? a.chapters.map(c=>({...c})) : []);
      const [errors, setErrors] = useState({});

      const inp = {width:'100%',background:C.surface2,border:`1px solid ${C.border}`,borderRadius:10,padding:'11px 13px',color:C.text,fontSize:14,outline:'none',transition:'border-color 0.2s'};
      const lbl = {fontSize:11,color:C.muted,display:'block',marginBottom:5,textTransform:'uppercase',letterSpacing:0.8};
      const fld = {marginBottom:16};

      const save = () => {
        if (!title.trim()) { setErrors({title:'Title is required'}); setTab('details'); return; }
        if (!author.trim()) { setErrors({author:'Author is required'}); setTab('details'); return; }
        const hasAnalysis = summary || tipsText || realLifeText || chapters.length > 0;
        onSave({
          ...book,
          volumeInfo: {
            ...v,
            title: title.trim(),
            authors: author.split(',').map(s=>s.trim()).filter(Boolean),
            imageLinks: coverUrl.trim() ? {thumbnail:coverUrl.trim(),smallThumbnail:coverUrl.trim()} : v.imageLinks,
            publishedDate: year.trim(),
            description: description.trim(),
          },
          analysis: hasAnalysis ? {
            summary: summary.trim(),
            goldenTips: tipsText.split('\n').map(s=>s.trim()).filter(Boolean),
            realLife: realLifeText.split('\n').map(s=>s.trim()).filter(Boolean),
            chapters: chapters.filter(c=>c.title.trim()),
          } : undefined,
        });
      };

      const addChapter = () => setChapters(ch=>[...ch,{title:'',summary:''}]);
      const delChapter = (i) => setChapters(ch=>ch.filter((_,idx)=>idx!==i));
      const updChapter = (i,field,val) => setChapters(ch=>ch.map((c,idx)=>idx===i?{...c,[field]:val}:c));

      const TabBtn = ({id,label,dot}) => (
        <button className="tab-btn" onClick={()=>setTab(id)}
          style={{background:tab===id?C.accent:'transparent',color:tab===id?'#fff':C.muted}}>
          {label}{dot&&<span style={{marginLeft:5,color:C.green,fontSize:10}}>●</span>}
        </button>
      );

      return (
        <div style={{position:'fixed',inset:0,background:'rgba(0,0,0,0.75)',display:'flex',alignItems:'center',justifyContent:'center',zIndex:200}} onClick={onClose}>
          <div style={{background:C.surface,border:`1px solid ${C.border}`,borderRadius:18,padding:32,width:580,maxWidth:'94vw',maxHeight:'92vh',overflowY:'auto',display:'flex',flexDirection:'column',gap:0}} onClick={e=>e.stopPropagation()}>
            <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:20}}>
              <h2 style={{fontSize:19,fontWeight:700}}>Edit Book</h2>
              <button onClick={onClose} style={{background:'transparent',border:'none',color:C.muted,fontSize:22,cursor:'pointer',lineHeight:1}}>×</button>
            </div>

            <div style={{display:'flex',gap:4,background:C.surface2,padding:4,borderRadius:10,marginBottom:24}}>
              <TabBtn id="details" label="Details" />
              <TabBtn id="analysis" label="Analysis" dot={!!book.analysis} />
            </div>

            {tab === 'details' && (
              <div>
                <div style={fld}>
                  <label style={lbl}>Title *</label>
                  <input value={title} onChange={e=>{setTitle(e.target.value);setErrors(v=>({...v,title:''}));}} autoFocus style={inp} />
                  {errors.title && <p style={{color:C.error,fontSize:12,marginTop:4}}>{errors.title}</p>}
                </div>
                <div style={fld}>
                  <label style={lbl}>Author *</label>
                  <input value={author} onChange={e=>{setAuthor(e.target.value);setErrors(v=>({...v,author:''}));}} style={inp} />
                  {errors.author && <p style={{color:C.error,fontSize:12,marginTop:4}}>{errors.author}</p>}
                </div>
                <div style={fld}>
                  <label style={lbl}>Cover Image URL</label>
                  <input value={coverUrl} onChange={e=>setCoverUrl(e.target.value)} placeholder="https://..." style={inp} />
                </div>
                <div style={fld}>
                  <label style={lbl}>Year</label>
                  <input value={year} onChange={e=>setYear(e.target.value)} placeholder="e.g. 1998" style={inp} />
                </div>
                <div style={fld}>
                  <label style={lbl}>Description</label>
                  <textarea value={description} onChange={e=>setDescription(e.target.value)} rows={3} style={{...inp,resize:'vertical',fontFamily:'inherit',lineHeight:1.6}} />
                </div>
              </div>
            )}

            {tab === 'analysis' && (
              <div>
                {!book.analysis && (
                  <div style={{marginBottom:18,padding:'12px 16px',background:'rgba(124,110,247,0.08)',border:`1px solid rgba(124,110,247,0.25)`,borderRadius:10,color:C.muted,fontSize:13}}>
                    No analysis yet. Generate one from the book view, or fill in manually below.
                  </div>
                )}
                <div style={fld}>
                  <label style={{...lbl,color:C.accent}}>Summary</label>
                  <textarea value={summary} onChange={e=>setSummary(e.target.value)} rows={5} placeholder="Write a summary of the book..." style={{...inp,resize:'vertical',fontFamily:'inherit',lineHeight:1.7}} />
                </div>
                <div style={fld}>
                  <label style={{...lbl,color:C.gold}}>Golden Tips</label>
                  <p style={{fontSize:11,color:C.muted,marginBottom:6}}>One tip per line</p>
                  <textarea value={tipsText} onChange={e=>setTipsText(e.target.value)} rows={6} placeholder={"Tip 1\nTip 2\nTip 3"} style={{...inp,resize:'vertical',fontFamily:'inherit',lineHeight:1.7}} />
                </div>
                <div style={fld}>
                  <label style={{...lbl,color:C.green}}>Real Life Takeaways</label>
                  <p style={{fontSize:11,color:C.muted,marginBottom:6}}>One takeaway per line</p>
                  <textarea value={realLifeText} onChange={e=>setRealLifeText(e.target.value)} rows={5} placeholder={"Takeaway 1\nTakeaway 2"} style={{...inp,resize:'vertical',fontFamily:'inherit',lineHeight:1.7}} />
                </div>
                <div style={fld}>
                  <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:10}}>
                    <label style={{...lbl,color:C.purple,margin:0}}>Chapter Summaries</label>
                    <button onClick={addChapter} style={{background:'transparent',border:`1px solid ${C.purple}`,color:C.purple,borderRadius:7,padding:'4px 12px',cursor:'pointer',fontSize:12,fontWeight:600}}>+ Add Chapter</button>
                  </div>
                  {chapters.length === 0 && <p style={{color:C.muted,fontSize:13,fontStyle:'italic'}}>No chapters yet. Click "+ Add Chapter" to add one.</p>}
                  {chapters.map((ch, i) => (
                    <div key={i} style={{background:C.surface2,borderRadius:10,padding:14,marginBottom:10,borderLeft:`3px solid ${C.purple}`}}>
                      <div style={{display:'flex',gap:8,alignItems:'center',marginBottom:8}}>
                        <input value={ch.title} onChange={e=>updChapter(i,'title',e.target.value)} placeholder={`Chapter ${i+1} title`} style={{...inp,flex:1,padding:'8px 12px'}} />
                        <button onClick={()=>delChapter(i)} style={{background:'transparent',border:'none',color:C.error,cursor:'pointer',fontSize:18,lineHeight:1,padding:'0 4px',flexShrink:0}}>×</button>
                      </div>
                      <textarea value={ch.summary} onChange={e=>updChapter(i,'summary',e.target.value)} placeholder="Chapter summary..." rows={2} style={{...inp,resize:'vertical',fontFamily:'inherit',lineHeight:1.6,fontSize:13}} />
                    </div>
                  ))}
                </div>
              </div>
            )}

            <div style={{display:'flex',gap:12,marginTop:8,paddingTop:16,borderTop:`1px solid ${C.border}`}}>
              <button onClick={save} style={{flex:1,padding:'13px',background:C.accent,border:'none',borderRadius:10,color:'#fff',fontWeight:700,cursor:'pointer',fontSize:15,transition:'filter 0.15s'}}>Save Changes</button>
              <button onClick={onClose} style={{padding:'13px 22px',background:'transparent',border:`1px solid ${C.border}`,borderRadius:10,color:C.muted,cursor:'pointer',fontSize:15}}>Cancel</button>
            </div>
          </div>
        </div>
      );
    }

    // ── Analysis Sections ────────────────────────────────────────────────────────
    function Section({ label, color, children }) {
      return (
        <div className="fade-in" style={{background:C.surface,border:`1px solid ${C.border}`,borderRadius:16,padding:26,marginBottom:14}}>
          <h3 style={{fontSize:15,fontWeight:700,color:color,marginBottom:18,textTransform:'uppercase',letterSpacing:1.2}}>{label}</h3>
          {children}
        </div>
      );
    }

    function SummarySection({ text }) {
      return (
        <Section label="Summary" color={C.accent}>
          <p style={{lineHeight:1.85,color:C.text,fontSize:15,whiteSpace:'pre-wrap'}}>{text}</p>
        </Section>
      );
    }

    function TipsSection({ tips }) {
      return (
        <Section label="Golden Tips" color={C.gold}>
          <ol style={{listStyle:'none',display:'flex',flexDirection:'column',gap:12}}>
            {tips.map((tip,i) => (
              <li key={i} style={{display:'flex',gap:14,alignItems:'flex-start'}}>
                <span style={{background:C.gold,color:'#08080f',fontWeight:800,fontSize:11,borderRadius:20,minWidth:22,height:22,display:'flex',alignItems:'center',justifyContent:'center',flexShrink:0,marginTop:2}}>{i+1}</span>
                <span style={{color:C.text,lineHeight:1.7,fontSize:15}}>{tip}</span>
              </li>
            ))}
          </ol>
        </Section>
      );
    }

    function RealLifeSection({ points }) {
      return (
        <Section label="Real Life Takeaways" color={C.green}>
          <ul style={{listStyle:'none',display:'flex',flexDirection:'column',gap:12}}>
            {points.map((pt,i) => (
              <li key={i} style={{display:'flex',gap:14,alignItems:'flex-start'}}>
                <span style={{color:C.green,fontSize:16,lineHeight:1,marginTop:3,fontWeight:700}}>›</span>
                <span style={{color:C.text,lineHeight:1.7,fontSize:15}}>{pt}</span>
              </li>
            ))}
          </ul>
        </Section>
      );
    }

    function ChaptersSection({ chapters }) {
      const [open, setOpen] = useState(null);
      return (
        <Section label="Chapter Summaries" color={C.purple}>
          <div style={{display:'flex',flexDirection:'column',gap:8}}>
            {chapters.map((ch, i) => (
              <div key={i} style={{background:C.surface2,borderRadius:12,overflow:'hidden',border:`1px solid ${C.border}`,borderLeft:`3px solid ${C.purple}`}}>
                <button
                  onClick={() => setOpen(open === i ? null : i)}
                  style={{width:'100%',display:'flex',alignItems:'center',justifyContent:'space-between',padding:'14px 18px',background:'transparent',border:'none',color:C.text,cursor:'pointer',textAlign:'left',gap:12}}
                >
                  <span style={{fontWeight:600,fontSize:14,color:C.purple}}>{ch.title}</span>
                  <span style={{color:C.muted,fontSize:12,flexShrink:0,transition:'transform 0.2s',transform:open===i?'rotate(180deg)':'none'}}>▼</span>
                </button>
                {open === i && (
                  <div style={{padding:'0 18px 16px',color:C.muted,lineHeight:1.75,fontSize:14,borderTop:`1px solid ${C.border}`}}>
                    <div style={{height:12}} />
                    {ch.summary}
                  </div>
                )}
              </div>
            ))}
          </div>
        </Section>
      );
    }

    // ── Main App ─────────────────────────────────────────────────────────────────
    function App() {
      const [apiKey, setApiKey] = useState(() => localStorage.getItem('lib_gemini_key') || '');
      const [showSettings, setShowSettings] = useState(false);
      const [query, setQuery] = useState('');
      const [suggestions, setSuggestions] = useState([]);
      const [loadingSug, setLoadingSug] = useState(false);
      const [showDrop, setShowDrop] = useState(false);
      const [book, setBook] = useState(null);
      const [analysis, setAnalysis] = useState(null);
      const [loading, setLoading] = useState(false);
      const [error, setError] = useState('');
      const [myBooks, setMyBooks] = useState(() => {
        try { return JSON.parse(localStorage.getItem('lib_my_books') || '[]'); }
        catch { return []; }
      });
      const [showAddModal, setShowAddModal] = useState(false);
      const [editingBook, setEditingBook] = useState(null);
      const wrapRef = useRef(null);

      const fetchBooks = useCallback(debounce(async (q) => {
        if (!q || q.length < 2) { setSuggestions([]); setShowDrop(false); return; }
        setLoadingSug(true);
        try {
          const url = `https://openlibrary.org/search.json?q=${encodeURIComponent(q)}&limit=8&fields=key,title,author_name,cover_i,first_publish_year,number_of_pages_median`;
          const res = await fetch(url);
          const data = await res.json();
          const normalized = (data.docs || []).map(doc => ({
            id: doc.key,
            volumeInfo: {
              title: doc.title,
              authors: doc.author_name || [],
              imageLinks: doc.cover_i
                ? { thumbnail: `https://covers.openlibrary.org/b/id/${doc.cover_i}-M.jpg`,
                    smallThumbnail: `https://covers.openlibrary.org/b/id/${doc.cover_i}-S.jpg` }
                : null,
              description: '',
              pageCount: doc.number_of_pages_median || null,
              publishedDate: doc.first_publish_year ? String(doc.first_publish_year) : '',
              categories: [],
            },
          }));
          setSuggestions(normalized);
          setShowDrop(normalized.length > 0);
        } catch(e) { setSuggestions([]); setShowDrop(false); }
        setLoadingSug(false);
      }, 350), []);

      useEffect(() => { fetchBooks(query); }, [query]);

      useEffect(() => {
        const down = (e) => { if (wrapRef.current && !wrapRef.current.contains(e.target)) setShowDrop(false); };
        document.addEventListener('mousedown', down);
        return () => document.removeEventListener('mousedown', down);
      }, []);

      const pick = (b) => {
        setBook(b); setQuery(b.volumeInfo.title);
        setShowDrop(false); setAnalysis(b.analysis || null); setError('');
      };

      const generate = async () => {
        if (!apiKey) { setShowSettings(true); return; }
        setLoading(true); setError(''); setAnalysis(null);
        try {
          const v = book.volumeInfo;
          const result = await callAI(apiKey, v.title, (v.authors||['Unknown']).join(', '), v.description);
          setAnalysis(result);
          const idx = myBooks.findIndex(b => b.id === book.id);
          if (idx !== -1) {
            const updated = [...myBooks];
            updated[idx] = { ...updated[idx], analysis: result };
            saveMyBooks(updated);
          }
        } catch(e) { setError(e.message); }
        setLoading(false);
      };

      const reset = () => { setBook(null); setQuery(''); setAnalysis(null); setError(''); setSuggestions([]); };

      const saveMyBooks = (updated) => {
        setMyBooks(updated);
        localStorage.setItem('lib_my_books', JSON.stringify(updated));
      };

      const addBook = ({ title, author, coverUrl, year, description }) => {
        const newBook = {
          id: 'manual_' + Date.now(),
          volumeInfo: {
            title: title.trim(),
            authors: [author.trim()],
            imageLinks: coverUrl.trim()
              ? { thumbnail: coverUrl.trim(), smallThumbnail: coverUrl.trim() }
              : null,
            pageCount: null,
            publishedDate: year.trim(),
            description: description.trim(),
            categories: [],
          },
        };
        saveMyBooks([...myBooks, newBook]);
      };

      const saveToLibrary = () => {
        if (!book || myBooks.some(b => b.id === book.id)) return;
        saveMyBooks([...myBooks, { ...book, ...(analysis ? { analysis } : {}) }]);
      };

      const removeBook = (bookId) => {
        saveMyBooks(myBooks.filter(b => b.id !== bookId));
        if (book && book.id === bookId) reset();
      };

      const saveEdit = (updatedBook) => {
        const idx = myBooks.findIndex(b => b.id === updatedBook.id);
        if (idx === -1) return;
        const updated = [...myBooks];
        updated[idx] = updatedBook;
        saveMyBooks(updated);
        setEditingBook(null);
        if (book && book.id === updatedBook.id) {
          setBook(updatedBook);
          setAnalysis(updatedBook.analysis || null);
        }
      };

      return (
        <div style={{minHeight:'100vh',background:C.bg,paddingBottom:80}}>

          {/* Header */}
          <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',padding:'22px 32px',borderBottom:`1px solid ${C.border}`,position:'sticky',top:0,background:C.bg,zIndex:100}}>
            <div style={{display:'flex',alignItems:'center',gap:16}}>
              <div style={{width:36,height:36,background:C.accent,borderRadius:10,display:'flex',alignItems:'center',justifyContent:'center'}}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round">
                  <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                </svg>
              </div>
              <span style={{fontSize:20,fontWeight:800,letterSpacing:0.5}}>Library</span>
            </div>
            <button onClick={()=>setShowSettings(true)} title="API Settings"
              style={{background:C.surface,border:`1px solid ${C.border}`,borderRadius:10,width:38,height:38,display:'flex',alignItems:'center',justifyContent:'center',cursor:'pointer',color:C.muted,transition:'color 0.15s,border-color 0.15s'}}>
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
              </svg>
            </button>
          </div>

          <div style={{maxWidth:760,margin:'0 auto',padding:'48px 24px 0'}}>

            {/* API key banner */}
            {!apiKey && (
              <div style={{marginBottom:28,padding:'14px 20px',background:'rgba(124,110,247,0.1)',border:`1px solid rgba(124,110,247,0.35)`,borderRadius:12,display:'flex',alignItems:'center',justifyContent:'space-between',gap:16}}>
                <span style={{fontSize:14,color:C.muted}}>Add your free Groq API key to enable AI analysis.</span>
                <button onClick={()=>setShowSettings(true)} style={{background:C.accent,border:'none',borderRadius:8,color:'#fff',fontWeight:700,fontSize:13,padding:'8px 16px',cursor:'pointer',flexShrink:0}}>Add Key</button>
              </div>
            )}

            {/* Search */}
            <div ref={wrapRef} style={{position:'relative',marginBottom:32}}>
              <div style={{display:'flex',alignItems:'center',background:C.surface,border:`1px solid ${C.border}`,borderRadius:14,transition:'border-color 0.2s',gap:4}}>
                <span style={{padding:'0 14px 0 18px',color:C.muted,display:'flex',alignItems:'center'}}>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                  </svg>
                </span>
                <input
                  value={query}
                  onChange={e=>{ setQuery(e.target.value); if(book)setBook(null); setAnalysis(null); }}
                  onFocus={()=>suggestions.length>0&&setShowDrop(true)}
                  placeholder="Search for a book by title or author..."
                  style={{flex:1,background:'transparent',border:'none',outline:'none',padding:'17px 0',fontSize:17,color:C.text}}
                />
                <div style={{padding:'0 16px',display:'flex',alignItems:'center',gap:8}}>
                  {loadingSug && <div className="spinner" />}
                  {(query||book) && (
                    <button onClick={reset} style={{background:'transparent',border:'none',color:C.muted,cursor:'pointer',fontSize:20,lineHeight:1,padding:0}}>&times;</button>
                  )}
                </div>
              </div>

              {showDrop && suggestions.length > 0 && (
                <div style={{position:'absolute',top:'calc(100% + 6px)',left:0,right:0,background:C.surface,border:`1px solid ${C.border}`,borderRadius:14,overflow:'hidden',zIndex:50,boxShadow:'0 16px 48px rgba(0,0,0,0.65)'}}>
                  {suggestions.map((s,idx) => {
                    const v = s.volumeInfo;
                    const img = v.imageLinks?.smallThumbnail?.replace('http:','https:');
                    return (
                      <div key={s.id} className="suggestion-item"
                        onClick={()=>pick(s)}
                        style={{display:'flex',alignItems:'center',gap:14,padding:'11px 16px',cursor:'pointer',borderBottom:idx<suggestions.length-1?`1px solid ${C.border}`:'none',transition:'background 0.1s'}}>
                        {img
                          ? <img src={img} style={{width:32,height:46,objectFit:'cover',borderRadius:4,flexShrink:0}} />
                          : <div style={{width:32,height:46,background:C.surface2,borderRadius:4,flexShrink:0}} />
                        }
                        <div style={{minWidth:0}}>
                          <div style={{fontWeight:600,fontSize:14,color:C.text,whiteSpace:'nowrap',overflow:'hidden',textOverflow:'ellipsis'}}>{v.title}</div>
                          <div style={{fontSize:12,color:C.muted,marginTop:3}}>{(v.authors||[]).join(', ')}{v.publishedDate?` · ${v.publishedDate.slice(0,4)}`:''}</div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              )}
            </div>

            {/* My Library */}
            {!book && !loading && (
              <LibraryGrid
                books={myBooks}
                onSelect={pick}
                onRemove={removeBook}
                onEdit={b => setEditingBook(b)}
                onAddClick={() => setShowAddModal(true)}
              />
            )}

            {/* Selected book */}
            {book && !analysis && !loading && (
              <div className="fade-in">
                <BookCard book={book} />
                <button
                  onClick={generate}
                  style={{width:'100%',marginTop:14,padding:'16px',background:C.accent,border:'none',borderRadius:14,color:'#fff',fontWeight:700,fontSize:16,cursor:'pointer',transition:'filter 0.15s',letterSpacing:0.3}}>
                  Generate AI Analysis
                </button>
                {myBooks.some(b => b.id === book.id)
                  ? <p style={{textAlign:'center',marginTop:10,fontSize:13,color:C.green,fontWeight:600}}>✓ Already in your library</p>
                  : <button onClick={saveToLibrary} style={{width:'100%',marginTop:8,padding:'13px',background:'transparent',border:`1px solid ${C.border}`,borderRadius:14,color:C.muted,fontWeight:600,fontSize:14,cursor:'pointer',transition:'filter 0.15s'}}>
                      + Save to Library
                    </button>
                }
              </div>
            )}

            {/* Loading */}
            {loading && (
              <div style={{textAlign:'center',padding:'60px 0',color:C.muted}}>
                <div style={{display:'flex',justifyContent:'center',marginBottom:20}}>
                  <div style={{width:36,height:36,border:`3px solid ${C.border}`,borderTop:`3px solid ${C.accent}`,borderRadius:'50%',animation:'spin 0.8s linear infinite'}} />
                </div>
                <p style={{fontSize:15}}>Analyzing <strong style={{color:C.text}}>{book?.volumeInfo.title}</strong>…</p>
                <p style={{fontSize:13,marginTop:8}}>This may take a few seconds.</p>
              </div>
            )}

            {/* Error */}
            {error && (
              <div style={{marginTop:16,padding:'16px 20px',background:'rgba(245,101,101,0.08)',border:`1px solid rgba(245,101,101,0.3)`,borderRadius:12,color:C.error,fontSize:14}}>
                <strong>Error:</strong> {error}
              </div>
            )}

            {/* Analysis */}
            {analysis && book && (
              <div className="fade-in">
                <BookCard book={book} />
                <div style={{marginTop:14}}>
                  {analysis.summary && <SummarySection text={analysis.summary} />}
                  {analysis.goldenTips?.length > 0 && <TipsSection tips={analysis.goldenTips} />}
                  {analysis.realLife?.length > 0 && <RealLifeSection points={analysis.realLife} />}
                  {analysis.chapters?.length > 0 && <ChaptersSection chapters={analysis.chapters} />}
                </div>
                <div style={{display:'flex',gap:10,marginTop:8}}>
                  <button
                    onClick={()=>setAnalysis(null)}
                    style={{flex:1,padding:'13px',background:'transparent',border:`1px solid ${C.border}`,borderRadius:14,color:C.muted,fontWeight:600,fontSize:14,cursor:'pointer',transition:'filter 0.15s'}}>
                    Regenerate Analysis
                  </button>
                  {myBooks.some(b => b.id === book.id)
                    ? <div style={{flex:1,padding:'13px',borderRadius:14,border:`1px solid ${C.green}`,color:C.green,fontWeight:600,fontSize:14,textAlign:'center'}}>✓ In Library</div>
                    : <button onClick={saveToLibrary} style={{flex:1,padding:'13px',background:C.surface,border:`1px solid ${C.accent}`,borderRadius:14,color:C.accent,fontWeight:700,fontSize:14,cursor:'pointer',transition:'filter 0.15s'}}>
                        + Save to Library
                      </button>
                  }
                </div>
              </div>
            )}

            {/* Empty state */}
            {myBooks.length === 0 && !book && !loading && !query && (
              <div style={{textAlign:'center',padding:'80px 0',color:C.muted}}>
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke={C.border} strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round" style={{marginBottom:20}}>
                  <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                </svg>
                <p style={{fontSize:17,fontWeight:600,color:C.text,marginBottom:8}}>Find your next book</p>
                <p style={{fontSize:14}}>Search any book and get an AI-powered analysis with summaries, tips, and chapter breakdowns.</p>
              </div>
            )}
          </div>

          {showSettings && (
            <SettingsModal
              apiKey={apiKey}
              onSave={key=>{ setApiKey(key); localStorage.setItem('lib_gemini_key', key); }}
              onClose={()=>setShowSettings(false)}
            />
          )}
          {showAddModal && (
            <AddBookModal
              onSave={(data) => { addBook(data); setShowAddModal(false); }}
              onClose={() => setShowAddModal(false)}
            />
          )}
          {editingBook && (
            <EditBookModal
              book={editingBook}
              onSave={saveEdit}
              onClose={() => setEditingBook(null)}
            />
          )}
        </div>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
