/* ════════════════════════════════════════════════════
   WEEKLY REVIEW
════════════════════════════════════════════════════ */
const WK_STORE = "vg_weekly_reviews";
const getWeekDates = () => {
  const n=new Date(),dow=n.getDay(),sun=new Date(n);
  sun.setDate(n.getDate()-dow);
  return Array.from({length:7},(_,i)=>{const d=new Date(sun);d.setDate(sun.getDate()+i);return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`;});
};
const getISOWeek = () => {
  const n=new Date(),d=new Date(Date.UTC(n.getFullYear(),n.getMonth(),n.getDate()));
  const day=d.getUTCDay()||7;d.setUTCDate(d.getUTCDate()+4-day);
  const yr=new Date(Date.UTC(d.getUTCFullYear(),0,1));
  return `${d.getUTCFullYear()}-W${String(Math.ceil((((d-yr)/86400000)+1)/7)).padStart(2,"0")}`;
};
const wkLabel = wk => {
  const [y,w]=wk.split("-W").map(Number);
  const jan4=new Date(y,0,4),dow=(jan4.getDay()||7);
  const mon=new Date(jan4);mon.setDate(jan4.getDate()-(dow-1)+(w-1)*7);
  const sun=new Date(mon);sun.setDate(mon.getDate()+6);
  const fmt=d=>`${d.getDate()} ${MONTHS[d.getMonth()]}`;
  return `${fmt(mon)} – ${fmt(sun)} ${y}`;
};

function WeeklyReviewSheet({habits,open,onClose,toast}) {
  const [tab,setTab]=useState("entry");
  const [reviews,setReviews]=useState(()=>{try{const s=localStorage.getItem(WK_STORE);return s?JSON.parse(s):[];}catch{return [];}});
  const wk=getISOWeek();
  const cur=reviews.find(r=>r.weekKey===wk)||{weekKey:wk,journal:"",weight:"",videoName:"",submittedAt:null};
  const [journal,setJournal]=useState(cur.journal||"");
  const [weight,setWeight]=useState(cur.weight||"");
  const [videoName,setVideoName]=useState(cur.videoName||"");
  const [videoUrl,setVideoUrl]=useState("");
  const [success,setSuccess]=useState(false);
  const [showHabitsDetail,setShowHabitsDetail]=useState(false);
  const nn=habits.filter(h=>h.isNN);
  const nnDone=nn.filter(h=>h.status==="complete").length;
  const pct=habits.length?Math.round(habits.filter(h=>h.status==="complete").length/habits.length*100):0;
  const weekDates=getWeekDates(); // [sun, mon, ..., sat]
  const scheduledHabits=habits.filter(h=>!h.isNN&&!h.isBad&&(h.days||[]).some(d=>d<7));
  const weekDone=scheduledHabits.reduce((s,h)=>{
    return s+(h.completedDates||[]).filter(d=>weekDates.includes(d)).length;
  },0);
  const weekScheduled=scheduledHabits.reduce((s,h)=>{
    return s+(h.days||[]).filter(d=>d<7).length;
  },0);
  const prev=reviews.filter(r=>r.weekKey!==wk).sort((a,b)=>b.weekKey.localeCompare(a.weekKey));

  const save=()=>{
    if(!journal.trim()&&!weight){toast("Add a journal entry or weight to save");return;}
    const entry={weekKey:wk,journal:journal.trim(),weight:weight||null,videoName:videoName||"",submittedAt:Date.now()};
    const next=[...reviews.filter(r=>r.weekKey!==wk),entry];
    setReviews(next);
    try{localStorage.setItem(WK_STORE,JSON.stringify(next));}catch{}
    setSuccess(true);setTimeout(()=>setSuccess(false),2400);
    toast("✓ Weekly review saved");
  };

  const onVideo=e=>{const f=e.target.files[0];if(!f)return;setVideoName(f.name);setVideoUrl(URL.createObjectURL(f));};

  if(!open)return null;
  return (<>
    <div style={C.ov} onClick={onClose}/>
    <div style={{...C.sh,maxHeight:"96dvh"}}>
      <ShDrag/>
      <ShHdr title="WEEKLY REVIEW" sub={wkLabel(wk)} subColor="var(--gold)" onClose={onClose}
        right={<div style={{display:"flex",gap:8}}>
          {["entry","history"].map(t=>(
            <button key={t} onClick={()=>setTab(t)} style={{padding:"6px 14px",borderRadius:20,fontFamily:"var(--fm)",fontSize:7.5,letterSpacing:".14em",textTransform:"uppercase",cursor:"pointer",background:tab===t?"linear-gradient(135deg,rgba(228,184,74,.2),rgba(228,184,74,.08))":"none",border:`1px solid ${tab===t?"rgba(228,184,74,.4)":"var(--e0)"}`,color:tab===t?"var(--gold)":"var(--t2)",transition:"all .22s ease"}}>
              {t==="entry"?"THIS WEEK":"HISTORY"}
            </button>
          ))}
          <button style={{width:36,height:36,borderRadius:12,background:"var(--g2)",border:"1px solid var(--e0)",color:"var(--t2)",fontSize:20,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center"}} onClick={onClose}>×</button>
        </div>}
      />

      {tab==="entry"&&<div style={C.shBody}>
        {/* Floating showcase card */}
        <div style={{position:"relative",marginBottom:28}}>
          <div style={{borderRadius:24,padding:"22px 22px 20px",background:"linear-gradient(145deg,rgba(228,184,74,.07),rgba(124,110,248,.06),rgba(45,212,160,.04))",border:"1px solid rgba(228,184,74,.18)",position:"relative",overflow:"hidden",animation:"float 4s ease-in-out infinite",boxShadow:"0 8px 48px rgba(0,0,0,.5),0 0 0 1px rgba(228,184,74,.08) inset"}}>
            {/* Corner glow */}
            <div style={{position:"absolute",top:-40,right:-40,width:120,height:120,borderRadius:"50%",background:"radial-gradient(circle,rgba(228,184,74,.12),transparent 70%)",pointerEvents:"none"}}/>
            <div style={{position:"absolute",bottom:-30,left:-30,width:90,height:90,borderRadius:"50%",background:"radial-gradient(circle,rgba(124,110,248,.1),transparent 70%)",pointerEvents:"none"}}/>
            <div style={{fontFamily:"var(--fm)",fontSize:8,letterSpacing:".22em",textTransform:"uppercase",color:"var(--gold)",marginBottom:16,opacity:.7}}>Week at a Glance</div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:14}}>
              {/* Habits Done — tappable button */}
              <button onClick={()=>setShowHabitsDetail(v=>!v)} style={{textAlign:"center",background:"none",border:"none",cursor:"pointer",padding:0,borderRadius:12,transition:"opacity .18s ease"}} title="See weekly breakdown">
                <div style={{fontFamily:"var(--fd)",fontSize:26,fontWeight:800,color:"var(--em)",lineHeight:1,filter:"drop-shadow(0 0 8px rgba(45,212,160,.4))"}}>{weekDone}/{weekScheduled}</div>
                <div style={{fontFamily:"var(--fm)",fontSize:7,color:showHabitsDetail?"var(--em)":"var(--t2)",letterSpacing:".12em",textTransform:"uppercase",marginTop:4,transition:"color .18s ease"}}>HABITS {showHabitsDetail?"▴":"▾"}</div>
              </button>
              {[
                {label:"NNs Complete",value:`${nnDone}/${nn.length}`,color:"var(--p)"},
                {label:"Score",value:`${pct}%`,color:"var(--gold)"},
              ].map(({label,value,color})=>(
                <div key={label} style={{textAlign:"center"}}>
                  <div style={{fontFamily:"var(--fd)",fontSize:26,fontWeight:800,color,lineHeight:1,filter:`drop-shadow(0 0 8px ${color}66)`}}>{value}</div>
                  <div style={{fontFamily:"var(--fm)",fontSize:7,color:"var(--t2)",letterSpacing:".12em",textTransform:"uppercase",marginTop:4}}>{label}</div>
                </div>
              ))}
            </div>
            {cur.submittedAt&&<div style={{marginTop:14,paddingTop:12,borderTop:"1px solid rgba(228,184,74,.12)",fontFamily:"var(--fm)",fontSize:8,color:"var(--t1)",letterSpacing:".08em"}}>
              Last saved: {new Date(cur.submittedAt).toLocaleDateString("en-GB",{day:"numeric",month:"short",hour:"2-digit",minute:"2-digit"})}
              {cur.weight&&<span style={{marginLeft:12,color:"var(--gold)"}}>⚖ {cur.weight} kg</span>}
            </div>}
          </div>
          {success&&<div style={{position:"absolute",inset:0,borderRadius:24,display:"flex",alignItems:"center",justifyContent:"center",background:"rgba(8,8,15,.88)",backdropFilter:"blur(8px)",animation:"fadeIn .2s ease",zIndex:2}}>
            <div style={{textAlign:"center"}}>
              <div style={{fontSize:40,animation:"bouncePop .45s cubic-bezier(.34,1.56,.64,1) both"}}>✓</div>
              <div style={{fontFamily:"var(--fm)",fontSize:9,color:"var(--em)",letterSpacing:".2em",marginTop:8}}>SAVED</div>
            </div>
          </div>}
        </div>

        {/* Habits detail accordion */}
        {showHabitsDetail&&<div style={{animation:"fadeUp .3s ease both",marginBottom:24}}>
          <div style={{fontFamily:"var(--fm)",fontSize:7.5,letterSpacing:".18em",textTransform:"uppercase",color:"var(--t1)",marginBottom:12}}>Habits This Week</div>
          {scheduledHabits.map(h=>{
            const scheduledCount=(h.days||[]).filter(d=>d<7).length;
            const doneThisWeek=(h.completedDates||[]).filter(d=>weekDates.includes(d)).length;
            return (
              <div key={h.id} style={{borderRadius:16,padding:"14px 16px",background:"rgba(255,255,255,.03)",border:"1px solid var(--e0)",marginBottom:10}}>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
                  <span style={{fontSize:13,color:"var(--t4)",fontWeight:500}}>{h.name}</span>
                  <Tag cls={doneThisWeek>0&&doneThisWeek===scheduledCount?"em":"dim"}>{doneThisWeek}/{scheduledCount}</Tag>
                </div>
                <div style={{display:"flex",gap:5}}>
                  {["S","M","T","W","T","F","S"].map((lbl,dow)=>{
                    const isSched=(h.days||[]).includes(dow);
                    const isDone=isSched&&(h.completedDates||[]).includes(weekDates[dow]);
                    return (
                      <div key={dow} style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:4}}>
                        <div style={{width:20,height:20,borderRadius:"50%",background:isDone?"var(--gold)":isSched?"rgba(255,255,255,.07)":"transparent",border:isSched?"1px solid rgba(255,255,255,.1)":"1px solid transparent",boxShadow:isDone?"0 0 10px rgba(228,184,74,.55)":"none",transition:"all .22s ease"}}/>
                        <span style={{fontFamily:"var(--fm)",fontSize:6.5,color:isSched?"var(--t2)":"rgba(255,255,255,.1)"}}>{lbl}</span>
                      </div>
                    );
                  })}
                </div>
              </div>
            );
          })}
        </div>}

        {/* Journal */}
        <Lbl style={{marginBottom:12}}>Journal Entry</Lbl>
        <div style={{marginBottom:6,fontFamily:"var(--fm)",fontSize:7.5,color:"var(--t1)",letterSpacing:".1em"}}>What I did · How I feel · What I can improve</div>
        <textarea style={{...C.fta,minHeight:120,borderColor:"rgba(228,184,74,.2)",caretColor:"var(--gold)",color:"var(--t5)",fontSize:14,lineHeight:1.75}} rows={5} value={journal} onChange={e=>setJournal(e.target.value)} placeholder="This week I focused on… I felt… Next week I want to improve…"/>

        {/* Weight */}
        <Lbl style={{marginBottom:12}}>Current Weight</Lbl>
        <div style={{display:"flex",alignItems:"center",gap:12,marginBottom:20}}>
          <input type="number" step="0.1" min="30" max="250" style={{...C.finput,marginBottom:0,flex:1,borderColor:"rgba(228,184,74,.2)",caretColor:"var(--gold)"}} value={weight} onChange={e=>setWeight(e.target.value)} placeholder="72.5"/>
          <div style={{fontFamily:"var(--fd)",fontSize:18,color:"var(--gold)",flexShrink:0,letterSpacing:".06em"}}>KG</div>
        </div>

        {/* Video */}
        <Lbl style={{marginBottom:12}}>Physique Video (360°)</Lbl>
        <label style={{display:"block",cursor:"pointer",marginBottom:20}}>
          <div style={{border:`2px dashed ${videoName?"rgba(45,212,160,.4)":"rgba(255,255,255,.1)"}`,borderRadius:18,padding:"20px 22px",textAlign:"center",background:videoName?"rgba(45,212,160,.04)":"rgba(255,255,255,.02)",transition:"all .22s ease"}}>
            {videoUrl?<video src={videoUrl} style={{width:"100%",borderRadius:12,maxHeight:180,objectFit:"cover"}} controls/>
            :<>
              <div style={{fontSize:28,marginBottom:8,animation:"float 3s ease-in-out infinite"}}>{videoName?"🎬":"📹"}</div>
              <div style={{fontFamily:"var(--fm)",fontSize:9,color:videoName?"var(--em)":"var(--t2)",letterSpacing:".14em",textTransform:"uppercase"}}>{videoName||"Tap to select video"}</div>
              {!videoName&&<div style={{fontFamily:"var(--fb)",fontSize:11,color:"var(--t1)",marginTop:4}}>MP4 · MOV · 360° walk-around</div>}
            </>}
          </div>
          <input type="file" accept="video/*" style={{display:"none"}} onChange={onVideo}/>
        </label>

        <button className="btn-shine btn-lift" style={{...C.btnPri,background:"linear-gradient(135deg,#b8902a,var(--gold),#f5d98a)",color:"#1a1200",boxShadow:"0 4px 28px rgba(228,184,74,.35),0 1px 0 rgba(255,255,255,.2) inset"}} onClick={save}>
          ✓ SAVE THIS WEEK'S REVIEW
        </button>
      </div>}

      {tab==="history"&&<div style={C.shBody}>
        {prev.length===0?<div style={{textAlign:"center",padding:"48px 0"}}>
          <div style={{fontSize:36,marginBottom:12,animation:"float 3s ease-in-out infinite"}}>📅</div>
          <div style={{fontFamily:"var(--fm)",fontSize:9,color:"var(--t2)",letterSpacing:".18em",textTransform:"uppercase"}}>No past reviews yet</div>
          <div style={{fontFamily:"var(--fb)",fontSize:13,color:"var(--t1)",marginTop:6}}>Complete this week's review to start your progress archive</div>
        </div>:prev.map((r,i)=>(
          <div key={r.weekKey} style={{borderRadius:20,padding:"18px 20px",background:"linear-gradient(145deg,rgba(255,255,255,.03),rgba(255,255,255,.01))",border:"1px solid var(--e0)",marginBottom:14,animationDelay:`${i*.05}s`}} className="au">
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
              <div style={{fontFamily:"var(--fd)",fontSize:13,fontWeight:700,color:"var(--gold)",letterSpacing:".06em"}}>{r.weekKey}</div>
              <div style={{display:"flex",gap:8,alignItems:"center"}}>
                {r.weight&&<Tag cls="am">{r.weight} kg</Tag>}
                {r.videoName&&<Tag cls="em">📹 video</Tag>}
              </div>
            </div>
            <div style={{fontFamily:"var(--fm)",fontSize:7.5,color:"var(--t1)",letterSpacing:".1em",marginBottom:8,textTransform:"uppercase"}}>{wkLabel(r.weekKey)}</div>
            {r.journal?<div style={{fontSize:13,color:"var(--t3)",lineHeight:1.65,display:"-webkit-box",WebkitLineClamp:4,WebkitBoxOrient:"vertical",overflow:"hidden"}}>{r.journal}</div>
            :<div style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t0)",letterSpacing:".1em",textTransform:"uppercase"}}>No journal entry</div>}
          </div>
        ))}
      </div>}
    </div>
  </>);
}

/* ════════════════════════════════════════════════════
   AUTH — LOGIN + APP ROOT
════════════════════════════════════════════════════ */
const ALLOWED_EMAIL = "ran.varsano@gmail.com";
const ALLOWED_CLIENT_ID = "980450679027-bffme0pdvmqqi0v6tt4vjaf4gtpcqg0t.apps.googleusercontent.com";

function LoginScreen({onAuth}) {
  const [error,setError] = useState("");
  const [saved,setSaved] = useState(()=>localStorage.getItem("vg_google_client_id")===ALLOWED_CLIENT_ID);
  const [clientId,setClientId] = useState(()=>localStorage.getItem("vg_google_client_id")===ALLOWED_CLIENT_ID?ALLOWED_CLIENT_ID:"");
  const btnRef = useRef(null);

  useEffect(()=>{
    if(!saved||!clientId)return;
    let attempts=0;
    const init=()=>{
      if(!window.google){if(++attempts<60){setTimeout(init,100);}return;}
      try{
        window.google.accounts.id.initialize({
          client_id:clientId,
          callback:(resp)=>{
            try{
              const payload=JSON.parse(atob(resp.credential.split('.')[1].replace(/-/g,'+').replace(/_/g,'/')));
              if(payload.email===ALLOWED_EMAIL){
                localStorage.setItem("vg_auth",JSON.stringify({email:payload.email,name:payload.name,picture:payload.picture,exp:payload.exp}));
                onAuth();
              }else{
                setError("Access denied. This app is private.");
              }
            }catch{setError("Sign-in failed. Try again.");}
          }
        });
        if(btnRef.current){
          window.google.accounts.id.renderButton(btnRef.current,{theme:"filled_black",size:"large",shape:"pill",width:280});
        }
      }catch(e){setError("Google Sign-In failed to load.");}
    };
    init();
  },[saved,clientId]);

  return (
    <div style={{minHeight:"100dvh",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",background:"var(--canvas)",padding:32,position:"relative",overflow:"hidden"}}>
      <div style={{position:"absolute",top:"20%",left:"50%",transform:"translateX(-50%)",width:400,height:400,borderRadius:"50%",background:"radial-gradient(circle,rgba(124,110,248,.08),transparent 70%)",pointerEvents:"none"}}/>
      <div style={{fontFamily:"var(--fd)",fontSize:52,fontWeight:800,letterSpacing:".04em",background:"linear-gradient(135deg,#818cf8,#67e8f9 60%,#a78bfa)",WebkitBackgroundClip:"text",WebkitTextFillColor:"transparent",backgroundClip:"text",marginBottom:8,animation:"textReveal .8s ease both"}}>VANGUARD</div>
      <div style={{fontFamily:"var(--fm)",fontSize:9,color:"var(--t2)",letterSpacing:".28em",textTransform:"uppercase",marginBottom:52,animation:"fadeUp .6s .2s ease both"}}>Private Dashboard</div>
      {!saved&&(
        <div style={{width:"100%",maxWidth:320,marginBottom:24,animation:"fadeUp .6s .3s ease both"}}>
          <div style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t2)",letterSpacing:".16em",textTransform:"uppercase",marginBottom:8}}>Google Client ID</div>
          <input value={clientId} onChange={e=>setClientId(e.target.value)} placeholder="Paste your Google OAuth Client ID" style={{width:"100%",padding:"13px 16px",background:"rgba(255,255,255,.04)",border:"1px solid rgba(255,255,255,.1)",borderRadius:16,color:"var(--t6)",fontFamily:"var(--fb)",fontSize:14,caretColor:"var(--p)",marginBottom:10,display:"block",boxSizing:"border-box"}}/>
          <button onClick={()=>{
            const id=clientId.trim();
            if(id!==ALLOWED_CLIENT_ID){setError("Access denied.");return;}
            localStorage.setItem("vg_google_client_id",id);setSaved(true);setError("");
          }} style={{width:"100%",padding:14,background:"linear-gradient(135deg,#5d50e6,#7c6ef8)",borderRadius:14,color:"#fff",fontFamily:"var(--fd)",fontSize:13,letterSpacing:".1em",cursor:"pointer",border:"none"}}>Save & Continue</button>
        </div>
      )}
      {saved&&<div ref={btnRef} style={{animation:"fadeUp .5s .1s ease both"}}/>}
      {error&&<div style={{marginTop:16,fontFamily:"var(--fm)",fontSize:10,color:"var(--ro)",letterSpacing:".08em"}}>{error}</div>}
      {saved&&<button onClick={()=>{localStorage.removeItem("vg_google_client_id");setSaved(false);setClientId("");}} style={{marginTop:20,background:"none",border:"none",fontFamily:"var(--fm)",fontSize:8,color:"var(--t1)",letterSpacing:".12em",cursor:"pointer",textDecoration:"underline",textTransform:"uppercase"}}>Change Client ID</button>}
    </div>
  );
}

function AppRoot() {
  const [authed,setAuthed] = useState(()=>{
    try{
      const a=JSON.parse(localStorage.getItem("vg_auth")||"null");
      if(!a)return false;
      if(Date.now()/1000>a.exp){localStorage.removeItem("vg_auth");return false;}
      return true;
    }catch{return false;}
  });
  if(!authed)return <LoginScreen onAuth={()=>setAuthed(true)}/>;
  return <App/>;
}

/* ════════════════════════════════════════════════════
   SIDEBAR (desktop only)
════════════════════════════════════════════════════ */
function Sidebar({screen,navigate,habits,goals,onCollapseChange}) {
  const [collapsed,setCollapsed]=useState(()=>localStorage.getItem("vg_sidebar_collapsed")==="1");
  const toggle=()=>{const n=!collapsed;setCollapsed(n);localStorage.setItem("vg_sidebar_collapsed",n?"1":"0");if(onCollapseChange)onCollapseChange(n);};
  const todayDow=new Date().getDay();
  const todayH=habits.filter(h=>!h.isNN&&!h.isBad&&!h.monthly&&(h.days||[]).includes(todayDow));
  const nn=habits.filter(h=>h.isNN);
  const nnDone=nn.filter(h=>h.status==="complete").length;
  const todayDone=todayH.filter(h=>h.status==="complete").length;
  const user=JSON.parse(localStorage.getItem("vg_auth")||"{}");
  const NAV=[{id:"home",ni:"⬡",nl:"Home"},{id:"habits",ni:"◈",nl:"Habits"},{id:"goals",ni:"⬢",nl:"Goals"},{id:"library",ni:"📖",nl:"Library"},{id:"profile",ni:"◉",nl:"Profile"}];
  const signOut=()=>{localStorage.removeItem("vg_auth");window.location.reload();};
  const W=collapsed?52:260;
  return (
    <div className="desktop-sidebar" style={{position:"fixed",top:0,left:0,bottom:0,width:W,background:"rgba(8,8,14,.98)",borderRight:"1px solid rgba(255,255,255,.06)",zIndex:200,flexDirection:"column",padding:"0 0 20px",backdropFilter:"blur(40px)",transition:"width .25s cubic-bezier(.22,1,.36,1)",overflow:"hidden"}}>
      {/* Branding + collapse toggle */}
      <div style={{padding:"24px 12px 18px",display:"flex",alignItems:"center",justifyContent:"space-between",minWidth:0,borderBottom:"1px solid rgba(255,255,255,.05)"}}>
        {!collapsed&&<div style={{minWidth:0}}>
          <div style={{fontFamily:"var(--fd)",fontSize:15,fontWeight:800,letterSpacing:".08em",background:"linear-gradient(135deg,#818cf8,#67e8f9)",WebkitBackgroundClip:"text",WebkitTextFillColor:"transparent",backgroundClip:"text",whiteSpace:"nowrap"}}>THE VANGUARD</div>
          <div style={{fontFamily:"var(--fm)",fontSize:7,color:"var(--t1)",letterSpacing:".2em",textTransform:"uppercase",marginTop:3}}>Personal OS</div>
        </div>}
        <button onClick={toggle} style={{width:28,height:28,borderRadius:8,background:"rgba(255,255,255,.04)",border:"1px solid rgba(255,255,255,.08)",color:"var(--t2)",fontSize:12,cursor:"pointer",flexShrink:0,display:"flex",alignItems:"center",justifyContent:"center",marginLeft:collapsed?0:"auto",transition:"all .2s ease"}}>
          {collapsed?"›":"‹"}
        </button>
      </div>
      {/* Nav */}
      <div style={{flex:1,padding:"12px 6px",display:"flex",flexDirection:"column",gap:2,overflowY:"auto",overflowX:"hidden"}}>
        {NAV.map(({id,ni,nl})=>(
          <button key={id} onClick={()=>navigate(id)} title={collapsed?nl:""} style={{display:"flex",alignItems:"center",gap:10,padding:"9px 10px",borderRadius:10,border:"none",cursor:"pointer",width:"100%",textAlign:"left",background:screen===id?"linear-gradient(135deg,rgba(124,110,248,.2),rgba(124,110,248,.09))":"transparent",color:screen===id?"var(--p)":"var(--t2)",transition:"all .18s ease",boxShadow:screen===id?"0 0 0 1px rgba(124,110,248,.22)":"none",justifyContent:collapsed?"center":"flex-start"}}>
            <span style={{fontSize:16,flexShrink:0,filter:screen===id?"drop-shadow(0 0 6px rgba(124,110,248,.6))":"none"}}>{ni}</span>
            {!collapsed&&<span style={{fontFamily:"var(--fb)",fontSize:13,fontWeight:screen===id?600:400,flex:1,whiteSpace:"nowrap",overflow:"hidden"}}>{nl}</span>}
            {!collapsed&&screen===id&&<div style={{width:5,height:5,borderRadius:"50%",background:"var(--p)",boxShadow:"0 0 8px var(--p)",flexShrink:0}}/>}
          </button>
        ))}
      </div>
      {/* Today's progress — hidden when collapsed */}
      {!collapsed&&<div style={{margin:"0 8px 12px",padding:"13px 14px",background:"rgba(255,255,255,.025)",border:"1px solid rgba(255,255,255,.05)",borderRadius:14}}>
        <div style={{fontFamily:"var(--fm)",fontSize:7,color:"var(--t1)",letterSpacing:".18em",textTransform:"uppercase",marginBottom:10}}>Today</div>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}}>
          <span style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t2)"}}>Non-Neg</span>
          <span style={{fontFamily:"var(--fd)",fontSize:14,fontWeight:800,color:"var(--em)"}}>{nnDone}/{nn.length}</span>
        </div>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
          <span style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t2)"}}>To Do</span>
          <span style={{fontFamily:"var(--fd)",fontSize:14,fontWeight:800,color:"var(--p)"}}>{todayDone}/{todayH.length}</span>
        </div>
      </div>}
      {/* Profile */}
      <div style={{display:"flex",alignItems:"center",gap:10,padding:"0 10px",cursor:"pointer",justifyContent:collapsed?"center":"flex-start"}} onClick={signOut} title={collapsed?`Sign out (${user.name||""})`:""}>
        {user.picture&&<img src={user.picture} style={{width:28,height:28,borderRadius:"50%",border:"1px solid rgba(255,255,255,.1)",flexShrink:0}} alt=""/>}
        {!collapsed&&<div style={{minWidth:0}}>
          <div style={{fontFamily:"var(--fb)",fontSize:12,color:"var(--t4)",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{user.name||"Vanguard"}</div>
          <div style={{fontFamily:"var(--fm)",fontSize:7,color:"var(--t1)",letterSpacing:".06em"}}>Sign out</div>
        </div>}
      </div>
    </div>
  );
}

/* ════════════════════════════════════════════════════
   ROOT APP
════════════════════════════════════════════════════ */
function App() {
  const [screen,setScreen] = useState("home");
  const [habits,setHabits] = useState(()=>{
    try{
      const s=localStorage.getItem("vg_habits");
      if(!s)return INIT_HABITS;
      const stored=JSON.parse(s);
      // Migrate: backfill days/completedDates/monthly/isNN/name from INIT_HABITS
      return stored.map(h=>{
        const def=INIT_HABITS.find(x=>x.id===h.id);
        return{
          ...h,
          name: def?.name ?? h.name,          // fix renamed habits (e.g. Instagram)
          isNN: def?.isNN ?? h.isNN,           // fix isNN changes
          isBad: def?.isBad ?? h.isBad ?? false,
          days: h.days ?? def?.days ?? [],
          monthly: h.monthly ?? def?.monthly ?? false,
          completedDates: h.completedDates ?? [],
          duration: h.duration ?? def?.duration ?? 0,
        };
      });
    }catch{return INIT_HABITS;}
  });
  const [goals,setGoals]   = useState(INIT_GOALS);
  const [books,setBooks]   = useState([]);
  const [nHid,setNHid]     = useState(26);
  const [nGid,setNGid]     = useState(4);
  const [nBid,setNBid]     = useState(1);
  const [googleApiKey,setGoogleApiKey] = useState(()=>localStorage.getItem("vg_google_api_key")||"");
  const [googleClientId,setGoogleClientId] = useState(()=>localStorage.getItem("vg_google_client_id")||"");
  const [googleConfigStatus,setGoogleConfigStatus] = useState("Not configured");
  const [syncOpen,setSyncOpen] = useState(false);
  const [reviewOpen,setReviewOpen] = useState(false);
  const [toastMsg,setToastMsg] = useState("");
  const [clock,setClock]   = useState("");
  const [sweepingId,setSweepingId] = useState(null);
  const [isDesktop,setIsDesktop] = useState(()=>window.innerWidth>=1024);
  const [sidebarCollapsed,setSidebarCollapsed] = useState(()=>localStorage.getItem("vg_sidebar_collapsed")==="1");
  const tRef = useRef(null);

  const toast = msg => { setToastMsg(msg); clearTimeout(tRef.current); tRef.current=setTimeout(()=>setToastMsg(""),2800); };

  // Detect desktop/mobile on resize
  useEffect(()=>{
    const h=()=>setIsDesktop(window.innerWidth>=1024);
    window.addEventListener('resize',h);
    return()=>window.removeEventListener('resize',h);
  },[]);

  const initialLoadDone = useRef(false);

  // On mount: load from GitHub first, then apply daily reset — single source of truth
  useEffect(()=>{
    const migrate=h=>{
      const def=INIT_HABITS.find(x=>x.id===h.id);
      return{...h,name:def?.name??h.name,isNN:def?.isNN??h.isNN,isBad:def?.isBad??h.isBad??false,days:h.days??def?.days??[],monthly:h.monthly??def?.monthly??false,completedDates:h.completedDates??[],duration:h.duration??def?.duration??0};
    };
    const applyReset=habits=>{
      const lastReset=localStorage.getItem('vg_last_reset')||'';
      const todayStr=today();
      if(lastReset===todayStr)return habits;
      const weekDates=getWeekDates();
      const reset=habits.map(habit=>{
        if(habit.monthly)return habit;
        const scheduled=(habit.days||[]).filter(d=>d<7).length;
        const done=(habit.completedDates||[]).filter(d=>weekDates.includes(d)).length;
        if(scheduled>0&&done>=scheduled)return habit;
        return{...habit,status:'pending'};
      });
      localStorage.setItem('vg_last_reset',todayStr);
      return reset;
    };
    const init=async()=>{
      let habits=null;
      try{
        const resp=await fetch(`https://raw.githubusercontent.com/DeVers-goat/morning-habits/main/habits.json?_=${Date.now()}`);
        if(resp.ok){
          const remote=await resp.json();
          if(Array.isArray(remote)&&remote.length>0) habits=remote.map(migrate);
        }
      }catch{}
      if(!habits){
        // Fallback to localStorage
        try{const s=localStorage.getItem("vg_habits");if(s)habits=JSON.parse(s).map(migrate);}catch{}
      }
      if(!habits) habits=INIT_HABITS;
      habits=applyReset(habits);
      try{localStorage.setItem("vg_habits",JSON.stringify(habits));}catch{}
      setHabits(habits);
      initialLoadDone.current=true;
    };
    init();
  },[]);

  // Persist habits to localStorage + habits.json + GitHub auto-push (skip during initial load)
  useEffect(()=>{
    if(!initialLoadDone.current)return;
    try{ localStorage.setItem("vg_habits", JSON.stringify(habits)); }catch{}
    writeHabitsFile(habits);
    pushHabitsToGitHub(habits);
  },[habits]);

  async function pushHabitsToGitHub(habits){
    try{
      const token=localStorage.getItem("vg_github_token")||"";
      if(!token)return;
      const repo="DeVers-goat/morning-habits";
      const path="habits.json";
      const apiBase=`https://api.github.com/repos/${repo}/contents/${path}`;
      const headers={"Authorization":`Bearer ${token}`,"Content-Type":"application/json","Accept":"application/vnd.github+json"};
      // Get current SHA (needed to update file)
      const getResp=await fetch(apiBase,{headers});
      if(!getResp.ok)return;
      const {sha}=await getResp.json();
      const content=btoa(unescape(encodeURIComponent(JSON.stringify(habits,null,2))));
      await fetch(apiBase,{method:"PUT",headers,body:JSON.stringify({message:"Auto-sync habits",content,sha})});
    }catch{}
  }

  function openHabitsDB(){return new Promise((res,rej)=>{const r=indexedDB.open("vg_handles",1);r.onupgradeneeded=e=>e.target.result.createObjectStore("h");r.onsuccess=e=>res(e.target.result);r.onerror=rej;});}
  async function writeHabitsFile(habits){
    try{
      const db=await openHabitsDB();
      const handle=await new Promise((res,rej)=>{const tx=db.transaction("h","readonly");const g=tx.objectStore("h").get("habits");g.onsuccess=()=>res(g.result||null);g.onerror=rej;});
      if(!handle)return;
      const perm=await handle.queryPermission({mode:"readwrite"});
      const granted=perm==="granted"?perm:await handle.requestPermission({mode:"readwrite"});
      if(granted!=="granted")return;
      const w=await handle.createWritable();
      await w.write(JSON.stringify(habits,null,2));
      await w.close();
    }catch{}
  }
  async function setupHabitsExport(){
    try{
      const handle=await window.showSaveFilePicker({suggestedName:"habits.json",types:[{description:"JSON",accept:{"application/json":[".json"]}}]});
      const db=await openHabitsDB();
      await new Promise((res,rej)=>{const tx=db.transaction("h","readwrite");tx.objectStore("h").put(handle,"habits");tx.oncomplete=res;tx.onerror=rej;});
      await writeHabitsFile(habits);
      toast("✓ Habits will auto-sync to habits.json");
    }catch(e){if(e.name!=="AbortError")toast("Could not set up file sync");}
  }

  const saveGoogleConfig = ()=>{
    try{
      localStorage.setItem("vg_google_api_key", googleApiKey);
      localStorage.setItem("vg_google_client_id", googleClientId);
      _gapiReady = false; _accessToken = null; // reset so next sync re-inits with new creds
      setGoogleConfigStatus("Saved. Click Connect → to authorize Google Calendar.");
      toast("Google Calendar settings saved");
    }catch(e){
      setGoogleConfigStatus("Unable to save settings locally.");
      console.error(e);
    }
  };

  const connectGoogle = async ()=>{
    if(!googleApiKey || !googleClientId){ toast("Enter API key and Client ID first"); return; }
    try{
      setGoogleConfigStatus("Initializing…");
      _gapiReady = false; _accessToken = null;
      await initGoogleCalendar(googleApiKey, googleClientId);
      await requestGoogleToken();
      setGoogleConfigStatus("✓ Connected to Google Calendar");
      toast("Google Calendar connected");
    }catch(e){
      setGoogleConfigStatus("Connection failed: " + e.message);
      toast("Google Calendar connection failed");
      console.error(e);
    }
  };

  useEffect(()=>{
    try{
      const storedKey = localStorage.getItem("vg_google_api_key")||"";
      const storedClient = localStorage.getItem("vg_google_client_id")||"";
      setGoogleApiKey(storedKey);
      setGoogleClientId(storedClient);
      if(storedKey && storedClient) setGoogleConfigStatus("Saved locally. Add to Google Cloud and connect.");
    }catch(e){
      console.error(e);
    }
  },[]);

  useEffect(()=>{
    const tick=()=>{const n=new Date();setClock(`${String(n.getHours()).padStart(2,"0")}:${String(n.getMinutes()).padStart(2,"0")}`);};
    tick();const id=setInterval(tick,15000);return()=>clearInterval(id);
  },[]);

  const onCycle = id => {
    const cyc={pending:"complete",complete:"failed",failed:"pending"};
    const td=today();
    setHabits(h=>h.map(x=>{
      if(x.id!==id)return x;
      const nx={...x,status:cyc[x.status],completedDates:[...(x.completedDates||[])]};
      if(nx.status==="complete"){
        nx.completedDates=[...new Set([...nx.completedDates,td])];
        toast(`✓ ${x.name}`);
        setSweepingId(id);
        setTimeout(()=>setSweepingId(s=>s===id?null:s),900);
      } else if(x.status==="complete"){
        nx.completedDates=nx.completedDates.filter(d=>d!==td);
      }
      return nx;
    }));
  };

  const NAV=[{id:"home",ni:"⬡",nl:"Home"},{id:"habits",ni:"◈",nl:"Habits"},{id:"goals",ni:"⬢",nl:"Goals"},{id:"library",ni:"📖",nl:"Library"},{id:"profile",ni:"◉",nl:"Profile"}];
  const [transDir,setTransDir] = useState('right');
  const navigate = id => {
    const order = NAV.map(n=>n.id);
    setTransDir(order.indexOf(id) >= order.indexOf(screen) ? 'right' : 'left');
    setScreen(id);
  };

  return (
    <div style={C.app}>
      {/* Desktop sidebar */}
      {isDesktop&&<Sidebar screen={screen} navigate={navigate} habits={habits} goals={goals} onCollapseChange={setSidebarCollapsed}/>}

      <div className={isDesktop?`desktop-content${sidebarCollapsed?" sidebar-collapsed":""}`:""}>
        {/* Mobile status bar */}
        <div className="mobile-status-bar" style={C.sb}>
          <span style={{fontFamily:"var(--fm)",fontSize:12,color:"var(--t2)",letterSpacing:".04em"}}>{clock}</span>
          <div style={{display:"flex",alignItems:"center",gap:8}}>
            <div style={{width:7,height:7,borderRadius:"50%",background:"var(--em)",boxShadow:"0 0 10px var(--em),0 0 22px rgba(45,212,160,.3)",animation:"breathe 3.2s ease-in-out infinite"}}/>
            <span style={{fontFamily:"var(--fm)",fontSize:10,color:"var(--p)",letterSpacing:".22em",opacity:.65}}>VANGUARD</span>
          </div>
        </div>

        {/* Screens */}
        <div key={screen} className={transDir==='right'?'screen-enter-right':'screen-enter-left'}>
          {screen==="home"    && <HomeScreen    habits={habits} goals={goals} onCycle={onCycle} onSync={()=>setSyncOpen(true)} sweepingId={sweepingId} isDesktop={isDesktop}/>}
          {screen==="habits"  && <HabitsScreen  habits={habits} setHabits={setHabits} nHid={nHid} setNHid={setNHid} onSync={()=>setSyncOpen(true)} onSetupExport={setupHabitsExport} onReview={()=>setReviewOpen(true)} sweepingId={sweepingId} isDesktop={isDesktop}/>}
          {screen==="goals"   && <GoalsScreen   goals={goals} setGoals={setGoals} nGid={nGid} setNGid={setNGid} showToast={toast}/>}
          {screen==="library" && <LibraryScreen books={books} setBooks={setBooks} nBid={nBid} setNBid={setNBid} toast={toast}/>}
          {screen==="profile" && <ProfileScreen habits={habits} onSync={()=>setSyncOpen(true)} googleApiKey={googleApiKey} googleClientId={googleClientId} googleConfigStatus={googleConfigStatus} setGoogleApiKey={setGoogleApiKey} setGoogleClientId={setGoogleClientId} saveGoogleConfig={saveGoogleConfig} connectGoogle={connectGoogle} toast={toast}/>}
        </div>
      </div>

      {/* Mobile bottom nav */}
      <nav style={C.nav} className="mobile-nav">
        {NAV.map(({id,ni,nl})=>(
          <button key={id} onClick={()=>navigate(id)} style={{display:"flex",flexDirection:"column",alignItems:"center",gap:3,padding:"8px 16px",borderRadius:52,border:"none",cursor:"pointer",transition:"all .28s cubic-bezier(.22,1,.36,1)",...(screen===id?{background:"linear-gradient(145deg,rgba(124,110,248,.22),rgba(124,110,248,.1))",color:"var(--p)",boxShadow:"0 0 0 1px rgba(124,110,248,.32),0 4px 24px rgba(124,110,248,.22)",animation:"glowPulse 3s ease-in-out infinite"}:{background:"none",color:"rgba(120,115,160,.6)"})}}>
            <span style={{fontSize:15,lineHeight:1,transform:screen===id?"scale(1.22)":"scale(1)",transition:"transform .3s cubic-bezier(.34,1.56,.64,1)",filter:screen===id?"drop-shadow(0 0 8px rgba(124,110,248,.6))":"none"}}>{ni}</span>
            <span style={{fontFamily:"var(--fm)",fontSize:"6px",letterSpacing:".18em",textTransform:"uppercase",opacity:screen===id?1:.5}}>{nl}</span>
          </button>
        ))}
      </nav>

      <SyncSheet habits={habits} open={syncOpen} onClose={()=>setSyncOpen(false)} toast={toast}/>
      <WeeklyReviewSheet habits={habits} open={reviewOpen} onClose={()=>setReviewOpen(false)} toast={toast}/>
      <Toast msg={toastMsg}/>
    </div>
  );
}
