  svg.appendChild(svgE("circle",{cx:CX,cy:CY,r:14,fill:"rgba(255,255,255,.04)",stroke:"rgba(255,255,255,.1)","stroke-width":"1"}));
  svgT(svg,CX,CY-4,new Date().getFullYear(),{fill:"rgba(200,195,255,.8)","font-family":"'Oxanium',sans-serif","font-size":"13","font-weight":"700","letter-spacing":"2"});
