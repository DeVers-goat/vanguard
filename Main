/* ── CALENDAR ────────────────────────────────────────── */
function openCalendarEvent(name, dateStr, timeStr, dur) {
  const [y,mo,d]=dateStr.split("-").map(Number),[h,m]=timeStr.split(":").map(Number);
  const start=new Date(y,mo-1,d,h,m), end=new Date(start.getTime()+dur*60000);
  if(pf()==="android"){
    const a=document.createElement("a");
    a.href=`intent://EDIT#Intent;action=android.intent.action.INSERT;type=vnd.android.cursor.dir%2Fevent;S.title=${encodeURIComponent(name)};l.beginTime=${start.getTime()};l.endTime=${end.getTime()};S.description=${encodeURIComponent("Non-Negotiable — The Vanguard")};S.allDay=false;package=com.samsung.android.calendar;end`;
    document.body.appendChild(a);a.click();document.body.removeChild(a);return;
  }
  const f=x=>`${x.getFullYear()}${String(x.getMonth()+1).padStart(2,"0")}${String(x.getDate()).padStart(2,"0")}T${String(x.getHours()).padStart(2,"0")}${String(x.getMinutes()).padStart(2,"0")}00`;
  const ics=["BEGIN:VCALENDAR","VERSION:2.0","PRODID:-//Vanguard//EN","CALSCALE:GREGORIAN",
    "BEGIN:VEVENT",`UID:vg-${Date.now()}@app`,`DTSTART:${f(start)}`,`DTEND:${f(end)}`,
    `SUMMARY:${name}`,"DESCRIPTION:Non-Negotiable — The Vanguard","STATUS:CONFIRMED",
    "BEGIN:VALARM","TRIGGER:-PT10M","ACTION:DISPLAY",`DESCRIPTION:${name} starting soon`,
    "END:VALARM","END:VEVENT","END:VCALENDAR"].join("\r\n");
  const url=URL.createObjectURL(new Blob([ics],{type:"text/calendar"}));
  const a=document.createElement("a");a.href=url;a.download=`${name.replace(/[^a-z0-9]/gi,"_")}.ics`;
  document.body.appendChild(a);a.click();
  setTimeout(()=>{document.body.removeChild(a);URL.revokeObjectURL(url);},1200);
}

// ── Google Calendar API ──────────────────────────────────────────────────────
let _gapiReady = false;
let _tokenClient = null;
let _accessToken = null;
let _tokenExpiry = 0;

function initGoogleCalendar(apiKey, clientId) {
  return new Promise((resolve, reject) => {
    if (!window.gapi || !window.google) { reject(new Error("Google scripts not loaded")); return; }
    gapi.load('client', async () => {
      try {
        await gapi.client.init({ apiKey, discoveryDocs: ['https://www.googleapis.com/discovery/v1/apis/calendar/v3/rest'] });
        _tokenClient = google.accounts.oauth2.initTokenClient({
          client_id: clientId,
          scope: 'https://www.googleapis.com/auth/calendar.events',
          callback: () => {}
        });
        _gapiReady = true;
        resolve();
      } catch(e) { reject(e); }
    });
  });
}

function requestGoogleToken() {
  return new Promise((resolve, reject) => {
    if (_accessToken && Date.now() < _tokenExpiry) { resolve(_accessToken); return; }
    _tokenClient.callback = (resp) => {
      if (resp.error) { reject(new Error(resp.error)); return; }
      _accessToken = resp.access_token;
      _tokenExpiry = Date.now() + (resp.expires_in - 60) * 1000;
      resolve(_accessToken);
    };
    _tokenClient.requestAccessToken({ prompt: _accessToken ? '' : 'consent' });
  });
}

async function createGoogleCalendarEvent(name, dateStr, timeStr, dur) {
  const apiKey = localStorage.getItem("vg_google_api_key");
  const clientId = localStorage.getItem("vg_google_client_id");
  if (!apiKey || !clientId) throw new Error("Google credentials not configured");
  if (!_gapiReady) await initGoogleCalendar(apiKey, clientId);
  await requestGoogleToken();
  const [y,mo,d] = dateStr.split("-").map(Number);
  const [h,m] = timeStr.split(":").map(Number);
  const start = new Date(y, mo-1, d, h, m);
  const end = new Date(start.getTime() + dur * 60000);
  const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
  const resp = await gapi.client.calendar.events.insert({
    calendarId: 'primary',
    resource: {
      summary: name,
      description: 'Non-Negotiable — The Vanguard',
      start: { dateTime: start.toISOString(), timeZone: tz },
      end: { dateTime: end.toISOString(), timeZone: tz },
      reminders: { useDefault: false, overrides: [{ method: 'popup', minutes: 10 }] }
    }
  });
  return resp.result;
}

/* ── AI CALLS ────────────────────────────────────────── */
async function aiCall(prompt, maxTokens=600) {
  const r = await fetch("https://api.anthropic.com/v1/messages", {
    method:"POST",
    headers:{"Content-Type":"application/json","anthropic-version":"2023-06-01"},
    body: JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:maxTokens,messages:[{role:"user",content:prompt}]})
  });
  if(!r.ok){const t=await r.text().catch(()=>"");throw new Error(`HTTP ${r.status}: ${t.slice(0,80)}`);}
  const d=await r.json();
  if(d.error) throw new Error(d.error.message);
  return d.content.filter(c=>c.type==="text").map(c=>c.text).join("").trim();
}

async function searchBooksAI(q) {
  const raw = await aiCall(
    `A user is typing to find a book. Their input (possibly incomplete, vague, or a description): "${q}"\n\nInfer what book(s) they most likely mean and return the best matches.\nReturn ONLY a JSON array, no markdown:\n[{"title":"Exact Book Title","author":"Full Author Name","year":"2024","genre":"Self-Help","desc":"One sentence about this book.","isbn":"9780525559474"}]\nRules:\n- Think carefully: partial words, descriptions, themes, or author fragments should all resolve to real books\n- isbn: the real ISBN-13 of the most common edition, digits only, no hyphens — used to load cover art so it MUST be correct\n- genre must be one of: Self-Help, Psychology, Business, Finance, History, Philosophy, Science, Biography, Fiction, Thriller, Leadership, Health, Spirituality, Economics\n- Only real published books — up to 6 results, best match first\nJSON array only, nothing else.`,
    650
  );
  const m = raw.match(/\[[\s\S]*\]/);
  if(!m) return [];
  try { return JSON.parse(m[0]); } catch { return []; }
}

async function searchGoogleBooks(q) {
  const apiKey = localStorage.getItem("vg_google_api_key");
  const url = `https://www.googleapis.com/books/v1/volumes?q=${encodeURIComponent(q)}&maxResults=8&langRestrict=en${apiKey?`&key=${apiKey}`:""}`;
  const res = await fetch(url);
  if (!res.ok) throw new Error("Google Books request failed");
  const data = await res.json();
  if (!data.items) return [];
  return data.items.map(item => {
    const v = item.volumeInfo || {};
    const ids = v.industryIdentifiers || [];
    const isbn = (ids.find(x=>x.type==="ISBN_13") || ids.find(x=>x.type==="ISBN_10") || {}).identifier || "";
    const thumb = (v.imageLinks?.thumbnail || v.imageLinks?.smallThumbnail || "").replace("http://","https://");
    const cat = (v.categories||[])[0] || "";
    const genre = cat.split(/[/&]/)[0].trim();
    return {
      title: v.title || "",
      author: (v.authors||[]).join(", "),
      year: (v.publishedDate||"").slice(0,4),
      genre,
      desc: v.description ? v.description.slice(0,160)+(v.description.length>160?"…":"") : "",
      isbn,
      thumbnail: thumb,
      color: genreHex(genre.toLowerCase())
    };
  }).filter(b => b.title);
}

async function generateBookAI(title, author) {
  const raw = await aiCall(
    `Analyze the book: "${title}"${author?` by ${author}`:""}\n\nReturn ONLY a JSON object:\n{"summary":"2-3 paragraph overview.","tips":["Tip 1","Tip 2","Tip 3","Tip 4","Tip 5","Tip 6","Tip 7","Tip 8"],"chapters":[{"title":"Ch name","summary":"2-3 sentence summary."}]}\nRules: summary=2-3 paragraphs, tips=6-8 actionable insights, chapters=all major chapters up to 15 with accurate titles. JSON only.`,
    4000
  );
  const m = raw.match(/\{[\s\S]*\}/);
  if(!m) throw new Error("No JSON in response");
  return JSON.parse(m[0]);
}

/* ── SVG NETWORK ─────────────────────────────────────── */
const NS = "http://www.w3.org/2000/svg";
const svgE=(t,a={})=>{const e=document.createElementNS(NS,t);Object.entries(a).forEach(([k,v])=>e.setAttribute(k,v));return e;};
const svgT=(p,x,y,txt,a={})=>{const e=svgE("text",{x,y,"text-anchor":"middle","dominant-baseline":"middle",...a});e.textContent=txt;p.appendChild(e);return e;};
const VW=390,VH=630,CX=195,CY=330;
const goalPos=(i,n)=>{if(n<=1)return{x:CX,y:CY};const wb=[0,.11,-.07,.14,-.04,.09,-.13,.07,-.11,.05,-.08,.06],rw=[0,7,-5,9,-3,6,-7,5,-9,4,-6,8];const ang=(i/n)*Math.PI*2-Math.PI/2+(wb[i%12]||0),r=(n<=2?108:n<=4?120:n<=6?132:144)+(rw[i%12]||0);return{x:CX+r*Math.cos(ang),y:CY+r*Math.sin(ang)};};
const moPos=m=>{const rw=[0,7,-6,9,-4,8,-7,6,-8,5,-6,7];const ang=((m-1)/12)*Math.PI*2-Math.PI/2;return{x:CX+(155+(rw[(m-1)%12]||0))*Math.cos(ang),y:CY+(155+(rw[(m-1)%12]||0))*Math.sin(ang)};};
const AMB=Array.from({length:72},(_,i)=>({x:((i*137.5+22)%366)+12,y:((i*97.3+18)%590)+20,r:i%5===0?1.3:i%3===0?.8:.45,o:i%7===0?.2:i%5===0?.13:i%3===0?.08:.04,sp:2.4+((i*.18)%1.3)}));
const AMB_E=Array.from({length:26},(_,i)=>{const a=AMB[i*2%72],b=AMB[(i*2+9)%72];return{x1:a.x,y1:a.y,x2:b.x,y2:b.y};});

function drawNetwork(svg,goals,sel,onGoal,onMonth){
  while(svg.lastChild&&svg.lastChild.tagName!=="defs")svg.removeChild(svg.lastChild);
  svg.appendChild(svgE("rect",{width:VW,height:VH,fill:"url(#bg-g)"}));
  svg.appendChild(svgE("rect",{width:VW,height:VH,fill:"url(#dotgrid)",opacity:".85"}));
  AMB_E.forEach(e=>svg.appendChild(svgE("line",{x1:e.x1,y1:e.y1,x2:e.x2,y2:e.y2,stroke:"rgba(124,110,248,.2)","stroke-width":".4",opacity:".06"})));
  AMB.forEach((p,i)=>{const c=svgE("circle",{cx:p.x,cy:p.y,r:p.r,fill:"rgba(150,140,255,.6)",opacity:p.o});c.style.animation=`nodePulse ${p.sp}s ease-in-out ${(i*.08)%2}s infinite`;svg.appendChild(c);});
  if(sel===null) drawOverview(svg,goals,onGoal);
  else{const g=goals.find(x=>x.id===sel);if(g)drawExpanded(svg,g,goals,onGoal,onMonth);}
}
function drawOverview(svg,goals,onGoal){
  [50,40].forEach((r,i)=>{const c=svgE("circle",{cx:CX,cy:CY,r,fill:"none",stroke:"rgba(124,110,248,.1)","stroke-width":i===0?".7":"1.1"});if(i===0)c.style.animation="nodePulse 4s ease-in-out infinite";svg.appendChild(c);});
  if(goals.length>=3)goals.forEach((g,i)=>{const p1=goalPos(i,goals.length),p2=goalPos((i+1)%goals.length,goals.length);svg.appendChild(svgE("line",{x1:p1.x,y1:p1.y,x2:p2.x,y2:p2.y,stroke:"rgba(100,90,220,.18)","stroke-width":".5","stroke-dasharray":"3 13"}));});
  goals.forEach((g,i)=>{const p=goalPos(i,goals.length),col=GC[g.color].hex;const mx=(CX+p.x)/2,my=(CY+p.y)/2;const path=svgE("path",{d:`M ${CX} ${CY} Q ${mx+(p.y-CY)*.09} ${my-(p.x-CX)*.09} ${p.x} ${p.y}`,stroke:col,"stroke-width":".85",fill:"none",opacity:".32","stroke-dasharray":"4 8"});path.classList.add("de");svg.appendChild(path);});
  svg.appendChild(svgE("circle",{cx:CX,cy:CY,r:30,fill:"rgba(10,10,22,.94)",stroke:"rgba(124,110,248,.3)","stroke-width":"1.5",filter:"url(#gf-hub)"}));
  svg.appendChild(svgE("circle",{cx:CX,cy:CY,r:22,fill:"none",stroke:"rgba(124,110,248,.12)","stroke-width":"1"}));
  svg.appendChild(svgE("circle",{cx:CX,cy:CY,r:14,fill:"rgba(255,255,255,.04)",stroke:"rgba(255,255,255,.1)","stroke-width":"1"}));
  svgT(svg,CX,CY-4,new Date().getFullYear(),{fill:"rgba(200,195,255,.8)","font-family":"'Oxanium',sans-serif","font-size":"13","font-weight":"700","letter-spacing":"2"});
  const tG=goals.reduce((a,g)=>a+Object.values(g.monthlyGoals).filter(m=>m.text).length,0);
  const dG=goals.reduce((a,g)=>a+Object.values(g.monthlyGoals).filter(m=>m.done&&m.text).length,0);
  svgT(svg,CX,CY+12,`${dG}/${tG||0}`,{fill:"rgba(124,110,248,.5)","font-family":"'JetBrains Mono',monospace","font-size":"8"});
  goals.forEach((g,i)=>{
    const p=goalPos(i,goals.length),c=GC[g.color];
    const done=Object.values(g.monthlyGoals).filter(m=>m.done&&m.text).length,tot=Object.values(g.monthlyGoals).filter(m=>m.text).length;
    const pct=tot?Math.round(done/tot*100):0,R=21;
    const grp=svgE("g");grp.style.cursor="pointer";grp.addEventListener("click",()=>onGoal(g.id));
    grp.appendChild(svgE("circle",{cx:p.x,cy:p.y,r:R+7,fill:"none",stroke:c.hex,"stroke-width":".5",opacity:".16"}));
    if(pct>0){const ci=2*Math.PI*(R+4);grp.appendChild(svgE("circle",{cx:p.x,cy:p.y,r:R+4,fill:"none",stroke:c.hex,"stroke-width":"1.2","stroke-dasharray":`${ci*pct/100} ${ci}`,"stroke-dashoffset":ci*.25,"stroke-linecap":"round",opacity:".55"}));}
    grp.appendChild(svgE("circle",{cx:p.x,cy:p.y,r:R,fill:"rgba(9,9,20,.94)",stroke:c.hex,"stroke-width":"1.4",filter:`url(#${c.gf})`}));
    grp.appendChild(svgE("circle",{cx:p.x,cy:p.y,r:R*.62,fill:`${c.hex}18`,stroke:"none"}));
    grp.appendChild(svgE("circle",{cx:p.x-R*.2,cy:p.y-R*.2,r:R*.22,fill:"rgba(255,255,255,.07)",stroke:"none"}));
    const ang=Math.atan2(p.y-CY,p.x-CX),lx=p.x+Math.cos(ang)*(R+21),ly=p.y+Math.sin(ang)*(R+21);
    const anch=p.x>CX+10?"start":p.x<CX-10?"end":"middle";
    const lines=wrapTxt(g.title,11);
    lines.forEach((line,li)=>svgT(grp,lx,ly+(lines.length>1?li===0?-7:7:0),line,{fill:c.hex,"font-family":"'Plus Jakarta Sans',sans-serif","font-size":"9","font-weight":"700","text-anchor":anch,opacity:".9"}));
    if(tot>0)svgT(grp,p.x,p.y,`${pct}%`,{fill:c.hex,"font-family":"'JetBrains Mono',monospace","font-size":"7.5",opacity:".8"});
    svg.appendChild(grp);
  });
  if(!goals.length){svgT(svg,CX,CY+35,"NO GOALS YET",{fill:"rgba(100,90,200,.2)","font-family":"'Oxanium',sans-serif","font-size":"16","letter-spacing":"4"});svgT(svg,CX,CY+56,"TAP + NEW GOAL",{fill:"rgba(100,90,200,.15)","font-family":"'JetBrains Mono',monospace","font-size":"9","letter-spacing":"2"});}
}
function drawExpanded(svg,g,goals,onGoal,onMonth){
  const c=GC[g.color],curM=new Date().getMonth()+1;
  const done=Object.values(g.monthlyGoals).filter(m=>m.done&&m.text).length,tot=Object.values(g.monthlyGoals).filter(m=>m.text).length;
  const pct=tot?Math.round(done/tot*100):0;
  [54,45].forEach((r,i)=>{const ring=svgE("circle",{cx:CX,cy:CY,r,fill:"none",stroke:c.hex,"stroke-width":i===0?".55":"1",opacity:i===0?".1":".2"});if(i===0)ring.style.animation="nodePulse 3.5s ease-in-out infinite";svg.appendChild(ring);});
  for(let m=1;m<=12;m++){const mp=moPos(m),mg=g.monthlyGoals[m],has=!!mg.text;const mx=(CX+mp.x)/2+(mp.y-CY)*.05,my=(CY+mp.y)/2-(mp.x-CX)*.05;const path=svgE("path",{d:`M ${CX} ${CY} Q ${mx} ${my} ${mp.x} ${mp.y}`,stroke:c.hex,"stroke-width":has?".95":".32",fill:"none",opacity:mg.done&&has?".6":has?".28":".09"});if(mg.done&&has){path.setAttribute("stroke-dasharray","5 7");path.classList.add("de");}else if(!has)path.setAttribute("stroke-dasharray","2 11");svg.appendChild(path);}
  if(pct>0){const ci=2*Math.PI*45;svg.appendChild(svgE("circle",{cx:CX,cy:CY,r:45,fill:"none",stroke:c.hex,"stroke-width":"1.6","stroke-dasharray":`${ci*pct/100} ${ci}`,"stroke-dashoffset":ci*.25,"stroke-linecap":"round",opacity:".5"}));}
  svg.appendChild(svgE("circle",{cx:CX,cy:CY,r:36,fill:"rgba(8,8,18,.96)",stroke:c.hex,"stroke-width":"1.8",filter:`url(#${c.gf})`}));
  svg.appendChild(svgE("circle",{cx:CX,cy:CY,r:26,fill:"none",stroke:c.hex,"stroke-width":".6",opacity:".18"}));
  svgT(svg,CX,CY-7,new Date().getFullYear(),{fill:c.hex,"font-family":"'Oxanium',sans-serif","font-size":"12","font-weight":"700","letter-spacing":"2",opacity:".9"});
  svgT(svg,CX,CY+10,`${done}/${tot||0}`,{fill:c.hex,"font-family":"'JetBrains Mono',monospace","font-size":"9",opacity:".7"});
  for(let m=1;m<=12;m++){
    const mp=moPos(m),mg=g.monthlyGoals[m],has=!!mg.text,isDone=mg.done&&has,isCur=m===curM,R=17;
    const grp=svgE("g");grp.style.cursor="pointer";grp.addEventListener("click",()=>onMonth(g.id,m));
    if(isCur){const pulse=svgE("circle",{cx:mp.x,cy:mp.y,r:R+5,fill:"none",stroke:c.hex,"stroke-width":"1"});pulse.style.animation="orbitRing 2.6s ease-in-out infinite";grp.appendChild(pulse);}
    grp.appendChild(svgE("circle",{cx:mp.x,cy:mp.y,r:R,fill:isDone?`${c.hex}1c`:"rgba(8,8,18,.92)",stroke:isDone?c.hex:isCur?c.hex:has?`${c.hex}60`:"rgba(80,70,160,.2)","stroke-width":isDone?"1.6":isCur?"1.8":has?"1.1":".5",filter:isDone||isCur?`url(#${c.gf})`:"none",opacity:has?"1":".5"}));
    const ang=Math.atan2(mp.y-CY,mp.x-CX),lx=mp.x+Math.cos(ang)*(R+15),ly=mp.y+Math.sin(ang)*(R+15);
    svgT(grp,lx,ly,MONTHS[m-1],{fill:isDone?c.hex:isCur?"rgba(210,205,255,.9)":has?"rgba(130,125,200,.72)":"rgba(75,70,140,.45)","font-family":"'JetBrains Mono',monospace","font-size":isCur?"8.5":"7.5","font-weight":isCur?"600":"400","text-anchor":mp.x>CX+10?"start":mp.x<CX-10?"end":"middle","letter-spacing":".5"});
    if(has)grp.appendChild(svgE("circle",{cx:mp.x,cy:mp.y,r:isDone?5:3.2,fill:isDone?c.hex:"rgba(100,95,200,.38)",stroke:"none"}));
    else svgT(grp,mp.x,mp.y,"+",{fill:"rgba(75,70,140,.4)","font-family":"'JetBrains Mono',monospace","font-size":"10"});
    svg.appendChild(grp);
  }
  goals.filter(x=>x.id!==g.id).slice(0,4).forEach((og,i)=>{
    const corners=[{x:30,y:95},{x:VW-30,y:95},{x:30,y:VH-54},{x:VW-30,y:VH-54}];
    const cp=corners[i],oc=GC[og.color];
    const cg=svgE("g");cg.style.cursor="pointer";cg.addEventListener("click",()=>onGoal(og.id));
    cg.appendChild(svgE("circle",{cx:cp.x,cy:cp.y,r:12,fill:"rgba(8,8,18,.94)",stroke:oc.hex,"stroke-width":"1.1",filter:`url(#${oc.gf})`,opacity:".62"}));
    svgT(cg,cp.x,cp.y,og.title.slice(0,3).toUpperCase(),{fill:oc.hex,"font-family":"'JetBrains Mono',monospace","font-size":"6.5",opacity:".78"});
    svg.appendChild(cg);
  });
}

