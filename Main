    <div>
      <div style={{fontFamily:"var(--fd)",fontSize:24,fontWeight:800,color:"var(--t6)",letterSpacing:".04em"}}>{title}</div>
      {sub&&<div style={{fontFamily:"var(--fm)",fontSize:8,letterSpacing:".18em",textTransform:"uppercase",marginTop:4,color:subColor}}>{sub}</div>}
    </div>
    {right||<button style={{width:36,height:36,borderRadius:12,background:"var(--g2)",border:"1px solid var(--e0)",color:"var(--t2)",fontSize:20,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center"}} onClick={onClose}>×</button>}
  </div>
);
const Toast = ({msg})=> msg?<div style={{position:"fixed",bottom:"calc(96px + var(--sab))",left:"50%",transform:"translateX(-50%)",background:"rgba(12,12,22,.98)",backdropFilter:"blur(32px)",border:"1px solid rgba(255,255,255,.1)",borderRadius:16,padding:"11px 20px",fontFamily:"var(--fm)",fontSize:11,color:"var(--t5)",letterSpacing:".06em",zIndex:1200,whiteSpace:"nowrap",boxShadow:"0 8px 48px rgba(0,0,0,.7),0 1px 0 rgba(255,255,255,.08) inset",animation:"fadeUp .3s ease",display:"flex",alignItems:"center",gap:8}}><div style={{width:3,height:16,borderRadius:2,background:"var(--em)",flexShrink:0}}/>{msg}</div>:null;

/* ── YEAR BAR ────────────────────────────────────────── */
function YearBar() {
  const pct=ypct(),d=doy(),cm=new Date().getMonth();
  const [w,setW]=useState(0);
  useEffect(()=>{const t=setTimeout(()=>setW(pct),150);return()=>clearTimeout(t);},[]);
  return (
    <div style={{padding:"16px 22px 20px",borderBottom:"1px solid var(--e0)"}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"baseline",marginBottom:12}}>
        <span style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t1)",letterSpacing:".22em",textTransform:"uppercase"}}>Year Progress</span>
        <div style={{display:"flex",alignItems:"baseline",gap:10}}>
          <span style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t2)"}}>Day {d} · {365-d} left</span>
          <span style={{fontFamily:"var(--fd)",fontSize:28,fontWeight:800,background:"linear-gradient(135deg,var(--p),#a78bfa)",WebkitBackgroundClip:"text",WebkitTextFillColor:"transparent",backgroundClip:"text"}}>{pct.toFixed(1)}%</span>
        </div>
      </div>
      <div style={{height:4,background:"rgba(255,255,255,.05)",borderRadius:4,position:"relative"}}>
        <div style={{height:"100%",borderRadius:4,background:"linear-gradient(90deg,#6d5ff5,var(--p),#c084fc)",boxShadow:"0 0 18px rgba(124,110,248,.55),0 0 6px rgba(124,110,248,.3)",width:`${w}%`,transition:"width 1.4s cubic-bezier(.22,1,.36,1)",position:"relative"}}>
          <div style={{position:"absolute",right:-2,top:-4,width:4,height:12,background:"#fff",borderRadius:3,boxShadow:"0 0 14px rgba(255,255,255,.9),0 0 6px rgba(124,110,248,1)"}}/>
        </div>
      </div>
      <div style={{display:"flex",justifyContent:"space-between",marginTop:8}}>
        {["J","F","M","A","M","J","J","A","S","O","N","D"].map((m,i)=>(
          <span key={i} style={{fontFamily:"var(--fm)",fontSize:i===cm?8:7,color:i===cm?"var(--p)":"rgba(255,255,255,.07)",fontWeight:i===cm?700:400,textShadow:i===cm?"0 0 10px rgba(124,110,248,.8)":"none",transition:"all .22s ease"}}>{m}</span>
        ))}
      </div>
    </div>
  );
}

/* ── HABIT ROW ───────────────────────────────────────── */
function HabitRow({h,idx,editMode,onCycle,onRename,onToggleNN,onToggleBad,onToggleDay,onSetDuration,onSetTime,onDelete,showTime=false,sweeping=false}) {
  const [nm,setNm]=useState(h.name);
  const weekDates=getWeekDates();
  const scheduled=(h.days||[]).filter(d=>d<7).length;
  const doneThisWeek=(h.completedDates||[]).filter(d=>weekDates.includes(d)).length;
  const isPerfectWeek=scheduled>0&&doneThisWeek>=scheduled;
  // For bad habits: complete=avoided(good/green), failed=indulged(red)
  const sc={
    complete:{border:"var(--em)",bg:"var(--em1)",color:"var(--em)"},
    failed:{border:"var(--ro)",bg:"var(--ro1)",color:"var(--ro)"},
    pending:{border:h.isBad?"rgba(240,98,146,.3)":"var(--t0)",bg:"none",color:"transparent"}
  }[h.status]||{border:"var(--t0)",bg:"none",color:"transparent"};
  const barBg = h.isBad
    ? h.status==="complete" ? "linear-gradient(to bottom,var(--em),rgba(45,212,160,.1))"
      : h.status==="failed" ? "linear-gradient(to bottom,var(--ro),rgba(240,98,146,.3))"
      : "linear-gradient(to bottom,rgba(240,98,146,.4),rgba(240,98,146,.1))"
    : h.isNN ? "linear-gradient(to bottom,var(--em),rgba(45,212,160,.2))"
    : h.status==="failed" ? "linear-gradient(to bottom,var(--ro),rgba(240,98,146,.15))"
    : h.status==="complete" ? "linear-gradient(to bottom,var(--em),rgba(45,212,160,.1))"
    : "rgba(255,255,255,.04)";
  const barShadow = h.isBad
    ? h.status==="failed" ? "2px 0 14px rgba(240,98,146,.4),1px 0 6px rgba(240,98,146,.25)" : h.status==="complete" ? "2px 0 14px rgba(45,212,160,.2)" : "2px 0 8px rgba(240,98,146,.15)"
    : (h.isNN||h.status==="complete") ? "2px 0 16px rgba(45,212,160,.25),1px 0 6px rgba(45,212,160,.15)"
    : h.status==="failed" ? "2px 0 10px rgba(240,98,146,.2)" : "none";
  const rowBg = h.status==="complete"?"rgba(45,212,160,.03)":h.isBad&&h.status==="failed"?"rgba(240,98,146,.04)":"rgba(8,8,15,.45)";
  const rowHover = h.status==="complete"?"rgba(45,212,160,.05)":h.isBad?"rgba(240,98,146,.06)":"rgba(255,255,255,.04)";
  return (
    <div style={{display:"flex",alignItems:"center",gap:13,padding:"14px 22px",background:rowBg,borderBottom:"1px solid rgba(255,255,255,.04)",position:"relative",animationDelay:`${idx*.03}s`,transition:"background .22s ease"}} className={`au${isPerfectWeek?" habit-gold":""}`}
      onMouseEnter={e=>e.currentTarget.style.background=rowHover}
      onMouseLeave={e=>e.currentTarget.style.background=rowBg}>
      {sweeping&&<div className="habit-sweep-overlay"/>}
      {isPerfectWeek&&<div className="habit-gold-sweep"/>}
      {isPerfectWeek&&!editMode&&<div style={{position:"absolute",left:"50%",transform:"translateX(-50%)",fontFamily:"var(--fm)",fontSize:10,letterSpacing:".18em",textTransform:"uppercase",color:"rgba(228,184,74,.55)",pointerEvents:"none",zIndex:8,whiteSpace:"nowrap",textShadow:"0 0 12px rgba(228,184,74,.3)"}}>✦ Done for the week</div>}
      <div style={{position:"absolute",left:0,top:8,bottom:8,width:3,borderRadius:"0 3px 3px 0",background:barBg,boxShadow:barShadow,transition:"all .3s ease"}}/>
      {editMode?<div style={{flex:1,display:"flex",flexDirection:"column",gap:6}}>
        <div style={{display:"flex",gap:8,alignItems:"center"}}>
          <input value={nm} onChange={e=>setNm(e.target.value)} onBlur={()=>onRename(h.id,nm)} style={{flex:1,background:"rgba(124,110,248,.08)",border:"1px solid rgba(124,110,248,.2)",borderRadius:10,padding:"7px 12px",color:"var(--t6)",fontSize:14,caretColor:"var(--p)"}}/>
          <button onClick={()=>onToggleNN(h.id)} style={{padding:"4px 10px",border:"1px solid var(--e0)",borderRadius:20,fontFamily:"var(--fm)",fontSize:7,background:h.isNN?"var(--em1)":"none",borderColor:h.isNN?"rgba(45,212,160,.3)":"var(--e0)",color:h.isNN?"var(--em)":"var(--t1)",cursor:"pointer",flexShrink:0}}>{h.isNN?"NN ✓":"NN"}</button>
          <button onClick={()=>onToggleBad(h.id)} style={{padding:"4px 10px",border:"1px solid var(--e0)",borderRadius:20,fontFamily:"var(--fm)",fontSize:7,background:h.isBad?"var(--ro1)":"none",borderColor:h.isBad?"rgba(240,98,146,.3)":"var(--e0)",color:h.isBad?"var(--ro)":"var(--t1)",cursor:"pointer",flexShrink:0}}>{h.isBad?"BAD ✓":"BAD"}</button>
          <button onClick={()=>onDelete(h.id)} style={{color:"var(--ro)",fontSize:20,cursor:"pointer",background:"none",border:"none",lineHeight:1,flexShrink:0}}>×</button>
        </div>
        {!h.isNN&&<DayPicker days={h.days||[]} onToggle={dow=>onToggleDay(h.id,dow)}/>}
        <div style={{display:"flex",alignItems:"center",gap:8,marginTop:4,flexWrap:"wrap"}}>
          <input type="time" value={h.time||"08:00"} onChange={e=>onSetTime(h.id,e.target.value)} style={{background:"rgba(255,255,255,.04)",border:"1px solid var(--e0)",borderRadius:8,padding:"3px 8px",color:"var(--t4)",fontFamily:"var(--fm)",fontSize:10,caretColor:"var(--p)"}}/>
          <input type="number" min="0" max="480" value={h.duration||0} onChange={e=>onSetDuration(h.id,Number(e.target.value))} style={{width:52,background:"rgba(255,255,255,.04)",border:"1px solid var(--e0)",borderRadius:8,padding:"3px 8px",color:"var(--t4)",fontFamily:"var(--fm)",fontSize:10,caretColor:"var(--p)",textAlign:"center"}}/>
          <span style={{fontFamily:"var(--fm)",fontSize:7,color:"var(--t1)"}}>min{h.duration>0?" → 📅":""}</span>
        </div>
      </div>:<>
        <button onClick={()=>onCycle(h.id)} style={{width:28,height:28,borderRadius:"50%",flexShrink:0,border:`1.5px solid ${sc.border}`,background:h.status==="complete"?"linear-gradient(135deg,var(--em),rgba(45,212,160,.6))":h.status==="failed"?"linear-gradient(135deg,var(--ro),rgba(240,98,146,.6))":"rgba(255,255,255,.03)",display:"flex",alignItems:"center",justifyContent:"center",cursor:"pointer",fontSize:11,color:h.status==="pending"?"transparent":"#fff",transition:"all .22s cubic-bezier(.34,1.56,.64,1)",boxShadow:h.status==="complete"?"0 0 0 3px rgba(45,212,160,.12),0 2px 8px rgba(45,212,160,.2)":h.status==="failed"?"0 0 0 3px rgba(240,98,146,.12)":"none"}}>{h.status==="complete"?"✓":h.status==="failed"?"✕":""}</button>
        {h.isNN&&<Tag cls="em">NN</Tag>}
        {h.isBad&&<Tag cls="ro">BAD</Tag>}
        <span style={{flex:1,fontSize:14,fontWeight:500,color:h.status==="complete"?"var(--t2)":h.isBad&&h.status==="failed"?"var(--ro)":"var(--t5)",textDecoration:h.status==="complete"?"line-through":"none",opacity:h.status==="failed"&&!h.isBad?.36:1}}>{h.name}</span>
        {showTime&&<span style={{fontFamily:"var(--fm)",fontSize:9,color:"var(--t1)",flexShrink:0,letterSpacing:".06em"}}>{h.time}</span>}
      </>}
    </div>
  );
}

/* ════════════════════════════════════════════════════
   HOME SCREEN
════════════════════════════════════════════════════ */
function HomeScreen({habits,goals,onCycle,onSync,sweepingId,isDesktop}) {
  const nn=habits.filter(h=>h.isNN),nnDone=nn.filter(h=>h.status==="complete").length;
  const todayDow=new Date().getDay();
  const todayHabits=habits.filter(h=>!h.isNN&&!h.isBad&&!h.monthly&&(h.days||[]).includes(todayDow));
  const todayDone=todayHabits.filter(h=>h.status==="complete").length;
  const tG=goals.reduce((a,g)=>a+Object.values(g.monthlyGoals).filter(m=>m.text).length,0);
  const dG=goals.reduce((a,g)=>a+Object.values(g.monthlyGoals).filter(m=>m.done&&m.text).length,0);
  const n=new Date(),DAYS=["SUNDAY","MONDAY","TUESDAY","WEDNESDAY","THURSDAY","FRIDAY","SATURDAY"],MOS=["JAN","FEB","MAR","APR","MAY","JUN","JUL","AUG","SEP","OCT","NOV","DEC"];
  return (
    <div style={C.screen}>
      <div style={{padding:"22px 22px 0",display:"flex",justifyContent:"space-between",alignItems:"flex-end"}}>
        <div className="text-reveal" style={{fontFamily:"var(--fd)",fontSize:44,fontWeight:800,color:"var(--t6)",lineHeight:.88,letterSpacing:".02em"}}>
          THE<div style={{background:"linear-gradient(135deg,#818cf8,#67e8f9 60%,#a78bfa)",WebkitBackgroundClip:"text",WebkitTextFillColor:"transparent",backgroundClip:"text",backgroundSize:"200% 100%",animation:"shimmer 6s linear infinite"}}>VANGUARD</div>
        </div>
        <div style={{textAlign:"right",paddingBottom:5}}>
          <div style={{fontFamily:"var(--fd)",fontSize:10,color:"var(--p)",letterSpacing:".22em"}}>{DAYS[n.getDay()]}</div>
          <div style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t1)",letterSpacing:".1em",marginTop:5}}>{MOS[n.getMonth()]} {n.getDate()}, {n.getFullYear()}</div>
        </div>
      </div>
      <div style={{margin:"20px 22px 0",height:1,background:"linear-gradient(to right,transparent,rgba(124,110,248,.4),rgba(45,212,160,.25),transparent)"}}/>
      <YearBar/>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8,margin:"18px 22px 0"}}>
        {[{v:`${todayDone}/${todayHabits.length}`,l:"To Do Today",cl:"var(--p)"},{v:`${nnDone}/${nn.length}`,l:"Non-Neg",cl:"var(--em)"},{v:tG?`${dG}/${tG}`:"—",l:"Goals Done",cl:"var(--gold)"}].map(({v,l,cl})=>(
          <div key={l} className="card-tilt card-accent" style={{background:"var(--g1)",border:"1px solid var(--e0)",borderRadius:22,padding:"16px 14px 14px",position:"relative",overflow:"hidden",color:cl,cursor:"default"}}>
            <div style={{position:"absolute",inset:0,background:"currentColor",opacity:.05,filter:"blur(24px)",pointerEvents:"none",borderRadius:22}}/>
            <div className="count-up" style={{fontFamily:"var(--fd)",fontSize:28,fontWeight:800,lineHeight:1,position:"relative"}} key={v}>{v}</div>
            <div style={{fontFamily:"var(--fm)",fontSize:7,letterSpacing:".16em",textTransform:"uppercase",color:"var(--t1)",marginTop:8}}>{l}</div>
          </div>
        ))}
      </div>
      <div style={{margin:"22px 22px 10px",display:"flex",justifyContent:"space-between",alignItems:"center"}}><Lbl>Non-Negotiables</Lbl><Tag cls="em">{nnDone}/{nn.length}</Tag></div>
      <div className="stagger" style={{borderTop:"1px solid var(--e0)"}}>
        {nn.length===0?<div style={{padding:22,textAlign:"center",fontFamily:"var(--fm)",fontSize:10,color:"var(--t1)"}}>No Non-Negotiables set</div>
          :nn.map((h,i)=><HabitRow key={h.id} h={h} idx={i} onCycle={onCycle} showTime sweeping={sweepingId===h.id}/>)}
      </div>
      <div style={{margin:"22px 22px 10px",display:"flex",justifyContent:"space-between",alignItems:"center"}}><Lbl>To Do Today</Lbl><Tag cls="p">{todayDone}/{todayHabits.length}</Tag></div>
      <div className="stagger" style={{borderTop:"1px solid var(--e0)"}}>
        {todayHabits.length===0?<div style={{padding:"16px 22px",fontFamily:"var(--fm)",fontSize:9,color:"var(--t1)",letterSpacing:".1em"}}>Nothing else scheduled today</div>
          :todayHabits.map((h,i)=><HabitRow key={h.id} h={h} idx={i} onCycle={onCycle} showTime sweeping={sweepingId===h.id}/>)}
      </div>
      <button onClick={onSync} style={{margin:"16px 22px 0",display:"flex",alignItems:"center",justifyContent:"center",gap:9,padding:"14px 18px",background:"var(--g1)",border:"1px solid var(--e0)",borderRadius:22,fontFamily:"var(--fm)",fontSize:9,letterSpacing:".16em",textTransform:"uppercase",color:"var(--t2)",cursor:"pointer",width:"calc(100% - 44px)"}}>
        {pfI()} Sync to {pfL()}
      </button>
      <div style={{margin:"22px 22px 10px",display:"flex",justifyContent:"space-between",alignItems:"center"}}><Lbl>Active Goals</Lbl><Tag cls="p">{goals.length} targets</Tag></div>
      <div style={{borderTop:"1px solid var(--e0)"}}>
        {goals.slice(0,3).map(g=>{const gc2=GC[g.color],f=Object.values(g.monthlyGoals).filter(m=>m.text&&m.done).length,t=Object.values(g.monthlyGoals).filter(m=>m.text).length;return(
          <div key={g.id} style={{display:"flex",alignItems:"center",gap:14,padding:"15px 22px",background:"rgba(8,8,15,.55)",borderBottom:"1px solid var(--e0)"}}>
            <div style={{width:3,borderRadius:3,background:gc2.hex,boxShadow:`0 0 12px ${gc2.hex}55`,alignSelf:"stretch",minHeight:28,flexShrink:0}}/>
            <div style={{flex:1,minWidth:0}}>
              <div style={{fontSize:14,fontWeight:600,color:"var(--t5)",whiteSpace:"nowrap",overflow:"hidden",textOverflow:"ellipsis"}}>{g.title}</div>
              <div style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t1)",letterSpacing:".1em"}}>{f}/{t||0} monthly goals done</div>
            </div>
            <div style={{fontFamily:"var(--fd)",fontSize:22,fontWeight:800,color:gc2.hex,flexShrink:0}}>{t?Math.round(f/t*100):0}%</div>
          </div>
        );})}
      </div>
    </div>
  );
}

/* ════════════════════════════════════════════════════
   HABITS SCREEN
════════════════════════════════════════════════════ */
const DayPicker = ({days, onToggle}) => {
  const labels=["S","M","T","W","T","F","S"];
  return (
    <div style={{display:"flex",gap:4,marginTop:8,flexWrap:"wrap"}}>
      {labels.map((l,dow)=>{
        const on=(days||[]).includes(dow);
        return <button key={dow} onClick={()=>onToggle(dow)} style={{width:24,height:24,borderRadius:"50%",fontFamily:"var(--fm)",fontSize:7.5,fontWeight:600,cursor:"pointer",border:`1px solid ${on?"var(--p)":"var(--e0)"}`,background:on?"rgba(124,110,248,.18)":"rgba(255,255,255,.03)",color:on?"var(--p)":"var(--t1)",transition:"all .18s ease",flexShrink:0}}>{l}</button>;
      })}
    </div>
  );
};

function HabitsScreen({habits,setHabits,nHid,setNHid,onSync,onSetupExport,onReview,sweepingId,isDesktop}) {
  const [em,setEm]=useState(false);
  const [showOther,setShowOther]=useState(false);
  const td=today();
  const cyc={pending:"complete",complete:"failed",failed:"pending"};
  const onCycle=id=>setHabits(h=>h.map(x=>{
    if(x.id!==id)return x;
    const nx={...x,status:cyc[x.status],completedDates:[...(x.completedDates||[])]};
    if(nx.status==="complete")nx.completedDates=[...new Set([...nx.completedDates,td])];
    else if(x.status==="complete")nx.completedDates=nx.completedDates.filter(d=>d!==td);
    return nx;
  }));
  const onRename=(id,v)=>setHabits(h=>h.map(x=>x.id===id?{...x,name:v.trim()||x.name}:x));
  const onToggleNN=id=>setHabits(h=>h.map(x=>x.id===id?{...x,isNN:!x.isNN,isBad:false}:x));
  const onToggleBad=id=>setHabits(h=>h.map(x=>x.id===id?{...x,isBad:!x.isBad,isNN:false}:x));
  const onToggleDay=(id,dow)=>setHabits(h=>h.map(x=>x.id===id?{...x,days:(x.days||[]).includes(dow)?(x.days||[]).filter(d=>d!==dow):[...(x.days||[]),dow].sort((a,b)=>a-b)}:x));
  const onSetDuration=(id,v)=>setHabits(h=>h.map(x=>x.id===id?{...x,duration:v}:x));
  const onSetTime=(id,v)=>setHabits(h=>h.map(x=>x.id===id?{...x,time:v}:x));
  const onDelete=id=>setHabits(h=>h.filter(x=>x.id!==id));
  const onAdd=isNN=>{setHabits(h=>[...h,{id:nHid,name:"New habit",time:"08:00",isNN,isBad:false,status:"pending",days:[],completedDates:[]}]);setNHid(n=>n+1);};
  const todayDow=new Date().getDay();
  const nn=habits.filter(h=>h.isNN);
  const todayHabits=habits.filter(h=>!h.isNN&&!h.isBad&&!h.monthly&&(h.days||[]).includes(todayDow));
  const otherHabits=habits.filter(h=>!h.isNN&&!h.isBad&&!h.monthly&&!(h.days||[]).includes(todayDow));
  const monthlyHabits=habits.filter(h=>h.monthly);
  const bad=habits.filter(h=>h.isBad);
  const mkRow=(h,i)=><HabitRow key={h.id} h={h} idx={i} editMode={em} onCycle={onCycle} onRename={onRename} onToggleNN={onToggleNN} onToggleBad={onToggleBad} onToggleDay={onToggleDay} onSetDuration={onSetDuration} onSetTime={onSetTime} onDelete={onDelete} sweeping={sweepingId===h.id}/>;
  return (
    <div style={C.screen}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"22px 22px 18px"}}>
        <div><div style={{fontFamily:"var(--fd)",fontSize:30,fontWeight:800,color:"var(--t6)",letterSpacing:".03em"}}>HABITS</div><Lbl style={{marginTop:4,fontSize:7}}>Daily Operating System</Lbl></div>
        <div style={{display:"flex",gap:8}}>
          <button style={{...C.btnGhost,padding:"6px 10px",fontSize:11}} title="Set up WhatsApp auto-sync" onClick={onSetupExport}>📲</button>
          <button style={{...C.btnGhost,background:em?"rgba(124,110,248,.12)":"rgba(255,255,255,.04)",borderColor:em?"rgba(124,110,248,.3)":"rgba(255,255,255,.08)",color:em?"var(--p)":"var(--t2)",transition:"all .22s ease",boxShadow:em?"0 0 16px rgba(124,110,248,.15)":"none"}} onClick={()=>setEm(x=>!x)}>{em?"DONE":"EDIT"}</button>
        </div>
      </div>
      <YearBar/>
      {/* Non-Negotiables + To Do Today — unified grid on desktop */}
      <div style={{margin:"20px 22px 10px",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
        <Lbl>Today's Habits</Lbl>
        <div style={{display:"flex",gap:8}}>
          <Tag cls="em">{nn.filter(h=>h.status==="complete").length}/{nn.length} NN</Tag>
          <Tag cls="p">{todayHabits.filter(h=>h.status==="complete").length}/{todayHabits.length}</Tag>
        </div>
      </div>
      <div className="stagger" style={{borderTop:"1px solid var(--e0)",display:isDesktop?"grid":"block",gridTemplateColumns:isDesktop?"1fr 1fr":"none"}}>
        {[...nn,...todayHabits].length===0
          ?<div style={{padding:"16px 22px",fontFamily:"var(--fm)",fontSize:9,color:"var(--t1)",letterSpacing:".1em"}}>Nothing scheduled for today</div>
          :[...nn,...todayHabits].map(mkRow)}
      </div>
      {em&&<><button onClick={()=>onAdd(true)} style={{display:"flex",alignItems:"center",gap:9,width:"100%",padding:"13px 22px",background:"none",border:"none",borderBottom:"1px solid var(--e0)",fontFamily:"var(--fm)",fontSize:9,letterSpacing:".16em",textTransform:"uppercase",color:"var(--t1)",cursor:"pointer"}}><span style={{fontSize:16}}>+</span> Add Non-Negotiable</button>
      <button onClick={()=>onAdd(false)} style={{display:"flex",alignItems:"center",gap:9,width:"100%",padding:"13px 22px",background:"none",border:"none",borderBottom:"1px solid var(--e0)",fontFamily:"var(--fm)",fontSize:9,letterSpacing:".16em",textTransform:"uppercase",color:"var(--t1)",cursor:"pointer"}}><span style={{fontSize:16}}>+</span> Add Habit</button></> }
      {/* Other Habits (not today) */}
      {(otherHabits.length>0||em)&&<>
        <button onClick={()=>setShowOther(v=>!v)} style={{display:"flex",justifyContent:"space-between",alignItems:"center",width:"100%",padding:"16px 22px 10px",background:"none",border:"none",cursor:"pointer",textAlign:"left"}}>
          <Lbl style={{opacity:.5,fontSize:7,flex:1}}>Other Habits</Lbl>
          <div style={{display:"flex",alignItems:"center",gap:8}}>
            <Tag cls="dim">{otherHabits.filter(h=>h.status==="complete").length}/{otherHabits.length}</Tag>
            <span style={{fontFamily:"var(--fm)",fontSize:10,color:"var(--t1)",transition:"transform .22s ease",display:"inline-block",transform:showOther?"rotate(180deg)":"rotate(0deg)"}}>▾</span>
          </div>
        </button>
        {showOther&&<div className="stagger" style={{borderTop:"1px solid rgba(255,255,255,.04)",opacity:.75}}>
          {otherHabits.map(mkRow)}
        </div>}
      </>}
      {/* Monthly */}
      {monthlyHabits.length>0&&<>
        <div style={{margin:"16px 22px 10px",display:"flex",justifyContent:"space-between",alignItems:"center"}}><Lbl style={{opacity:.5,fontSize:7}}>Monthly</Lbl><Tag cls="dim">{monthlyHabits.filter(h=>h.status==="complete").length}/{monthlyHabits.length}</Tag></div>
        <div style={{borderTop:"1px solid rgba(255,255,255,.04)",opacity:.7}}>{monthlyHabits.map(mkRow)}</div>
      </>}
      {/* Bad Habits */}
      {bad.length>0&&<><div style={{margin:"20px 22px 10px",display:"flex",justifyContent:"space-between",alignItems:"center"}}><Lbl style={{color:"var(--ro)"}}>Bad Habits</Lbl><Tag cls="ro">{bad.filter(h=>h.status==="complete").length}/{bad.length} avoided</Tag></div>
      <div className="stagger" style={{borderTop:"1px solid rgba(240,98,146,.15)"}}>{bad.map(mkRow)}</div></>}
      <div style={{margin:"16px 22px 0",display:"flex",gap:10}}>
        <button onClick={onSync} style={{flex:1,display:"flex",alignItems:"center",justifyContent:"center",gap:9,padding:"14px 18px",background:"var(--g1)",border:"1px solid var(--e0)",borderRadius:22,fontFamily:"var(--fm)",fontSize:9,letterSpacing:".16em",textTransform:"uppercase",color:"var(--t2)",cursor:"pointer"}}>
          {pfI()} Sync Calendar
        </button>
        <button onClick={onReview} className="btn-shine" style={{flex:1,display:"flex",alignItems:"center",justifyContent:"center",gap:9,padding:"14px 18px",background:"linear-gradient(135deg,rgba(228,184,74,.14),rgba(228,184,74,.06))",border:"1px solid rgba(228,184,74,.3)",borderRadius:22,fontFamily:"var(--fm)",fontSize:9,letterSpacing:".16em",textTransform:"uppercase",color:"var(--gold)",cursor:"pointer",boxShadow:"0 0 20px rgba(228,184,74,.08)"}}>
          ✦ Weekly Review
        </button>
      </div>
    </div>
  );
}

/* ════════════════════════════════════════════════════
   GOALS SCREEN
════════════════════════════════════════════════════ */
function GoalsScreen({goals,setGoals,nGid,setNGid,showToast}) {
  const [sel,setSel]=useState(null);
  const [editGoal,setEditGoal]=useState(null);
  const [moSheet,setMoSheet]=useState(null);
  const svgRef=useRef(null);
  const dashRef=useRef(null);
  const onGoal=useCallback(id=>setSel(id),[]);
  const onMonth=useCallback((gid,m)=>setMoSheet({gid,m}),[]);
  useEffect(()=>{
    if(!svgRef.current)return;
    if(dashRef.current)clearInterval(dashRef.current);
    let tick=0;
    drawNetwork(svgRef.current,goals,sel,onGoal,onMonth);
    dashRef.current=setInterval(()=>{tick++;const off=-(tick*.42)%22;svgRef.current?.querySelectorAll(".de").forEach(e=>e.setAttribute("stroke-dashoffset",off));},55);
    return()=>clearInterval(dashRef.current);
  },[goals,sel,onGoal,onMonth]);
  const yr=new Date().getFullYear();
  const sg=goals.find(x=>x.id===sel);
  const gc2=sg?GC[sg.color]:null;
  const tG=goals.reduce((a,g)=>a+Object.values(g.monthlyGoals).filter(m=>m.text).length,0);
  const dG=goals.reduce((a,g)=>a+Object.values(g.monthlyGoals).filter(m=>m.done&&m.text).length,0);
  return (
    <div style={{height:"100dvh",padding:0,position:"relative",overflow:"hidden"}}>
      <div style={{position:"absolute",top:0,left:0,right:0,zIndex:20,padding:"calc(var(--sat) + 16px) 22px 18px",background:"linear-gradient(to bottom,rgba(8,8,15,.97) 58%,transparent)"}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start"}}>
          <div>
            {!sel?<div style={{fontFamily:"var(--fd)",fontSize:26,fontWeight:800,color:"var(--t6)",letterSpacing:".04em"}}>GOAL <span style={{background:"linear-gradient(135deg,#818cf8,#67e8f9)",WebkitBackgroundClip:"text",WebkitTextFillColor:"transparent",backgroundClip:"text"}}>NETWORK</span></div>
              :<div style={{fontFamily:"var(--fd)",fontSize:26,fontWeight:800,color:"var(--t6)",letterSpacing:".04em"}}>{sg?.title.toUpperCase()}</div>}
            <div style={{fontFamily:"var(--fm)",fontSize:8,letterSpacing:".2em",textTransform:"uppercase",marginTop:5,color:gc2?gc2.hex:"var(--t2)"}}>
              {!sel?`${goals.length} goals · ${dG}/${tG||0} complete · ${yr}`:`${Object.values(sg.monthlyGoals).filter(m=>m.done&&m.text).length}/${Object.values(sg.monthlyGoals).filter(m=>m.text).length||0} complete · ${gc2.label} · ${yr}`}
            </div>
          </div>
          <div style={{display:"flex",gap:8,paddingTop:3}}>
            {sel&&<><button style={C.btnGhost} onClick={()=>setSel(null)}>← BACK</button><button style={{...C.btnGhost,color:gc2.hex,borderColor:`${gc2.hex}44`}} onClick={()=>setEditGoal(goals.find(x=>x.id===sel))}>EDIT</button></>}
            {!sel&&<button style={C.btnAcc} onClick={()=>setEditGoal({id:null,title:"",color:"vi"})}>+ NEW GOAL</button>}
          </div>
        </div>
      </div>
      <svg ref={svgRef} viewBox="0 0 390 630" preserveAspectRatio="xMidYMid meet" style={{width:"100%",height:"100%",display:"block",touchAction:"manipulation"}}>
        <defs>
          <pattern id="dotgrid" width="26" height="26" patternUnits="userSpaceOnUse"><circle cx="1" cy="1" r=".6" fill="rgba(124,110,248,0.18)"/></pattern>
          <radialGradient id="bg-g" cx="50%" cy="48%" r="72%"><stop offset="0%" stopColor="#0e0e20"/><stop offset="100%" stopColor="#060610"/></radialGradient>
          {[["gf-vi",".49 0 0 0 0 .43 0 0 0 0 .98 0 0 0 0 0 0 0 1.3 0"],["gf-em",".18 0 0 0 0 .83 0 0 0 0 .63 0 0 0 0 0 0 0 1.3 0"],["gf-am",".96 0 0 0 0 .65 0 0 0 0 .14 0 0 0 0 0 0 0 1.3 0"],["gf-ro",".94 0 0 0 0 .38 0 0 0 0 .57 0 0 0 0 0 0 0 1.3 0"],["gf-sk",".22 0 0 0 0 .7 0 0 0 0 .97 0 0 0 0 0 0 0 1.3 0"],["gf-or",".98 0 0 0 0 .44 0 0 0 0 .21 0 0 0 0 0 0 0 1.3 0"]].map(([id,vals])=>(
            <filter key={id} id={id} x="-100%" y="-100%" width="300%" height="300%"><feGaussianBlur stdDeviation="6" result="b"/><feColorMatrix in="b" type="matrix" values={vals}/><feMerge><feMergeNode/><feMergeNode in="SourceGraphic"/></feMerge></filter>
          ))}
          <filter id="gf-hub" x="-80%" y="-80%" width="260%" height="260%"><feGaussianBlur stdDeviation="5" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        </defs>
      </svg>
      {editGoal!==null&&<GoalEditSheet goal={editGoal} goals={goals} setGoals={setGoals} nGid={nGid} setNGid={setNGid} onClose={()=>setEditGoal(null)} setSel={setSel} toast={showToast}/>}
      {moSheet&&<MonthSheet gid={moSheet.gid} month={moSheet.m} goals={goals} setGoals={setGoals} onClose={()=>setMoSheet(null)} toast={showToast}/>}
    </div>
  );
}
function GoalEditSheet({goal,goals,setGoals,nGid,setNGid,onClose,setSel,toast}) {
  const isNew=!goal.id;
  const [title,setTitle]=useState(goal.title||"");
  const [color,setColor]=useState(goal.color||"vi");
  const save=()=>{if(!title.trim()){toast("Enter a goal title");return;}if(isNew){setGoals(g=>[...g,{id:nGid,title:title.trim(),color,monthlyGoals:mkMo()}]);setNGid(n=>n+1);toast("Goal created");}else{setGoals(g=>g.map(x=>x.id===goal.id?{...x,title:title.trim(),color}:x));toast("Goal updated");}onClose();};
  const del=()=>{setGoals(g=>g.filter(x=>x.id!==goal.id));setSel(null);toast("Goal deleted");onClose();};
  return (<Sheet open onClose={onClose}>
    <ShDrag/><ShHdr title={isNew?"NEW GOAL":"EDIT GOAL"} sub={GC[color]?.label} subColor={GC[color]?.hex} onClose={onClose}/>
    <div style={C.shBody}>
      <label style={C.flabel}>Goal Title</label>
      <input style={C.finput} value={title} onChange={e=>setTitle(e.target.value)} placeholder="What will you conquer this year?" maxLength={60}/>
      <label style={C.flabel}>Category</label>
      <div style={{display:"flex",flexWrap:"wrap",gap:8,marginBottom:22}}>
        {Object.entries(GC).map(([k,v])=>(
          <div key={k} onClick={()=>setColor(k)} style={{display:"flex",alignItems:"center",gap:8,padding:"8px 14px",borderRadius:16,border:`1px solid ${color===k?"rgba(255,255,255,.2)":"var(--e0)"}`,cursor:"pointer",background:color===k?"rgba(255,255,255,.07)":"var(--g1)"}}>
            <div style={{width:11,height:11,borderRadius:"50%",background:v.hex,boxShadow:color===k?`0 0 10px ${v.hex}`:""}}/>
            <span style={{fontFamily:"var(--fm)",fontSize:8,letterSpacing:".12em",textTransform:"uppercase",color:color===k?v.hex:"var(--t2)"}}>{v.label}</span>
          </div>
        ))}
      </div>
      <div style={{display:"flex",gap:10}}>
        <button style={{...C.btnPri,flex:1}} onClick={save}>SAVE GOAL</button>
        {!isNew&&<button style={C.btnDng} onClick={del}>DELETE</button>}
      </div>
    </div>
  </Sheet>);
}
function MonthSheet({gid,month,goals,setGoals,onClose,toast}) {
  const g=goals.find(x=>x.id===gid);const c=GC[g?.color]||GC.vi;const mg=g?.monthlyGoals[month]||{text:"",done:false};
  const [text,setText]=useState(mg.text||"");
  const save=()=>{setGoals(gs=>gs.map(x=>x.id!==gid?x:{...x,monthlyGoals:{...x.monthlyGoals,[month]:{...x.monthlyGoals[month],text:text.trim()}}}));onClose();};
  const clear=()=>{setGoals(gs=>gs.map(x=>x.id!==gid?x:{...x,monthlyGoals:{...x.monthlyGoals,[month]:{text:"",done:false}}}));onClose();};
  const toggleDone=()=>{const d=!mg.done;setGoals(gs=>gs.map(x=>x.id!==gid?x:{...x,monthlyGoals:{...x.monthlyGoals,[month]:{...x.monthlyGoals[month],done:d}}}));if(d)toast("✓ Monthly goal complete");};
  return (<Sheet open onClose={save} sx={{borderTopColor:c.hex,boxShadow:`0 -8px 60px rgba(0,0,0,.75),0 0 0 1px ${c.hex}44`}}>
    <ShDrag/>
    <div style={{padding:"14px 22px 18px",borderBottom:"1px solid var(--e0)",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
      <div><div style={{fontFamily:"var(--fd)",fontSize:24,fontWeight:800,color:"var(--t6)"}}>{MONTHS_F[month-1].toUpperCase()}</div><div style={{fontFamily:"var(--fm)",fontSize:8,letterSpacing:".18em",textTransform:"uppercase",marginTop:4,color:c.hex}}>{g?.title}</div></div>
      {mg.text&&<button onClick={toggleDone} style={{padding:"10px 18px",background:mg.done?"var(--em1)":"var(--g1)",border:`1px solid ${mg.done?"rgba(45,212,160,.28)":"var(--e0)"}`,borderRadius:16,color:mg.done?"var(--em)":"var(--t2)",fontFamily:"var(--fm)",fontSize:8,letterSpacing:".14em",textTransform:"uppercase",cursor:"pointer"}}>{mg.done?"✓ DONE":"MARK DONE"}</button>}
    </div>
    <div style={C.shBody}>
      <label style={C.flabel}>Monthly Target</label>
      <textarea style={{...C.fta,borderColor:`${c.hex}44`,caretColor:c.hex}} rows={3} value={text} onChange={e=>setText(e.target.value)} placeholder="What will you achieve this month?"/>
      <div style={{display:"flex",gap:10}}>
        <button style={{...C.btnPri,flex:1,background:`linear-gradient(135deg,${c.hex},${c.hex}99)`,boxShadow:`0 4px 28px ${c.hex}44`}} onClick={save}>SAVE</button>
        {mg.text&&<button style={C.btnDng} onClick={clear}>CLEAR</button>}
      </div>
    </div>
  </Sheet>);
}

/* ════════════════════════════════════════════════════
   LIBRARY SCREEN + BOOK COMPONENTS
════════════════════════════════════════════════════ */
function BookCover({book, size=48}) {
  // Try 3 sources in order: ISBN cover → title cover → styled fallback
  const isbn   = (book.isbn||"").replace(/\D/g,"");
  const src1   = isbn   ? `https://covers.openlibrary.org/b/isbn/${isbn}-M.jpg`          : "";
  const src2   = book.title||book.name ? `https://covers.openlibrary.org/b/title/${encodeURIComponent((book.title||book.name||"").replace(/ /g,"+"))}-M.jpg` : "";
  const src3   = book.thumbnail || "";           // Google Books thumbnail if passed through
  const sources = [src3, src1, src2].filter(Boolean);
  const [idx, setIdx] = useState(0);
  const currentSrc = sources[idx] || "";

  const col = genreHex(book.genre) || book.color || BOOK_COLORS[(book.id||1) % BOOK_COLORS.length];
  const w = size, h = Math.round(size * 1.42);
  const sp = Math.max(3, Math.round(size / 13));
  const fs = size < 44 ? 8 : size < 60 ? 10 : 12;

  const onErr = () => {
    if (idx < sources.length - 1) setIdx(i => i + 1);
    else setIdx(sources.length); // show fallback
  };
  const showImg = currentSrc && idx < sources.length;

  return (
    <div style={{width:w,height:h,borderRadius:7,flexShrink:0,overflow:"hidden",position:"relative",
      background:`linear-gradient(150deg,${col}28,${col}0c)`,
      border:`1px solid ${col}40`,boxShadow:"2px 3px 14px rgba(0,0,0,.45)"}}>
      {/* Spine */}
      <div style={{position:"absolute",left:0,top:0,bottom:0,width:sp,
        background:`linear-gradient(to bottom,${col},${col}bb)`,
        boxShadow:`1px 0 6px ${col}66`, zIndex:2}}/>
      {showImg
        ? <img key={currentSrc} src={currentSrc} alt={book.title||book.name||""}
            style={{position:"absolute",inset:0,width:"100%",height:"100%",objectFit:"cover"}}
            onError={onErr}/>
        : <>
            <div style={{position:"absolute",inset:`0 0 ${Math.max(4,Math.round(size/10))}px ${sp}px`,
              display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",
              padding:"6px 6px 4px"}}>
              <div style={{fontFamily:"var(--fd)",fontSize:fs,fontWeight:800,color:col,textAlign:"center",
                lineHeight:1.2,wordBreak:"break-word",display:"-webkit-box",
                WebkitLineClamp:4,WebkitBoxOrient:"vertical",overflow:"hidden"}}>
                {book.title||book.name}
              </div>
              {book.author && <div style={{fontFamily:"var(--fm)",fontSize:Math.max(6,fs-2),
                color:`${col}88`,textAlign:"center",letterSpacing:".03em",marginTop:4,
                overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",maxWidth:"100%"}}>
                {book.author.split(" ").pop()}
              </div>}
            </div>
            <div style={{position:"absolute",bottom:0,left:sp,right:0,
              height:Math.max(4,Math.round(size/10)),
              background:`linear-gradient(to right,${col}99,${col}44)`}}/>
          </>}
    </div>
  );
}

function LibraryScreen({books,setBooks,nBid,setNBid,toast}) {
  const [filter,setFilter]=useState("all");
  const [detail,setDetail]=useState(null);
  const [editBook,setEditBook]=useState(null);
  const [searchOpen,setSearchOpen]=useState(false);
  const filtered=filter==="all"?books:books.filter(b=>b.status===filter);
  const stl=s=>s==="reading"?"Reading":s==="done"?"Done":"Want to Read";
  const stc=s=>s==="reading"?"sk":s==="done"?"em":"p";
  const saveBook=data=>{if(data.id){setBooks(b=>b.map(x=>x.id===data.id?data:x));toast("Book updated");}else{const col=BOOK_COLORS[(nBid-1)%BOOK_COLORS.length];setBooks(b=>[...b,{...data,id:nBid,color:col}]);setNBid(n=>n+1);toast("Book added to library");}setEditBook(null);};
  const delBook=id=>{setBooks(b=>b.filter(x=>x.id!==id));setDetail(null);setEditBook(null);toast("Book removed");};
  return (
    <div style={C.screen}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"22px 22px 18px"}}>
        <div><div style={{fontFamily:"var(--fd)",fontSize:30,fontWeight:800,color:"var(--t6)",letterSpacing:".03em"}}>LIBRARY</div><Lbl style={{marginTop:4,fontSize:7}}>Knowledge Arsenal</Lbl></div>
        <button style={C.btnAcc} onClick={()=>setSearchOpen(true)}>+ ADD BOOK</button>
      </div>
      <div style={{padding:"0 22px 14px",display:"flex",gap:6,overflowX:"auto"}}>
        {[["all","All"],["reading","Reading"],["done","Done"],["want","Want"]].map(([f,l])=>(
          <button key={f} onClick={()=>setFilter(f)} style={{padding:"6px 16px",borderRadius:60,border:`1px solid ${filter===f?"rgba(124,110,248,.35)":"rgba(255,255,255,.07)"}`,background:filter===f?"linear-gradient(135deg,rgba(124,110,248,.2),rgba(124,110,248,.1))":"rgba(255,255,255,.03)",fontFamily:"var(--fm)",fontSize:8.5,letterSpacing:".12em",textTransform:"uppercase",color:filter===f?"var(--p)":"rgba(150,145,190,.6)",cursor:"pointer",whiteSpace:"nowrap",boxShadow:filter===f?"0 0 0 1px rgba(124,110,248,.35),0 4px 20px rgba(124,110,248,.18)":"none",transition:"all .22s ease"}}>{l}</button>
        ))}
      </div>
      {filtered.length===0?<div style={{padding:"60px 22px",textAlign:"center"}}><div style={{fontSize:48,marginBottom:16,opacity:.4,display:"inline-block",animation:"breathe 3s ease-in-out infinite"}}>📚</div><div style={{fontFamily:"var(--fd)",fontSize:20,color:"var(--t3)",letterSpacing:".06em",marginBottom:8}}>No books yet</div><div style={{fontFamily:"var(--fm)",fontSize:9,color:"var(--t1)",letterSpacing:".12em"}}>Tap + ADD BOOK to begin</div></div>:
        <div className="stagger" style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,padding:"0 22px"}}>
          {filtered.map((b,i)=>{
            const col=b.color||BOOK_COLORS[(b.id-1)%BOOK_COLORS.length];
            const chC=(b.chapters||[]).filter(c=>c.title||c.summary).length,tipC=(b.tips||[]).filter(t=>t).length;
            return(<div key={b.id} onClick={()=>setDetail(b.id)} style={{background:"linear-gradient(160deg,rgba(255,255,255,.065) 0%,rgba(255,255,255,.03) 100%)",border:"1px solid rgba(255,255,255,.07)",borderRadius:20,overflow:"hidden",cursor:"pointer",position:"relative",boxShadow:"0 4px 24px rgba(0,0,0,.5),0 1px 0 rgba(255,255,255,.06) inset"}} className="card-tilt card-hover">
              <div style={{position:"absolute",top:0,left:0,right:0,height:2,background:`linear-gradient(to right,${col},${col}66,transparent)`,zIndex:2}}/>
              <div style={{width:"100%",aspectRatio:"2/3",background:`linear-gradient(160deg,${col}20,${col}08)`,display:"flex",alignItems:"center",justifyContent:"center",overflow:"hidden",position:"relative"}}>
                <BookCover book={{...b,title:b.name}} size={110}/>
                <div style={{position:"absolute",bottom:0,left:0,right:0,height:"45%",background:"linear-gradient(to top,rgba(8,8,15,.95) 0%,transparent 100%)",zIndex:1}}/>
              </div>
              <div style={{padding:"10px 12px 14px"}}>
                <div style={{fontSize:12,fontWeight:700,color:"var(--t5)",lineHeight:1.3,marginBottom:4,overflow:"hidden",textOverflow:"ellipsis",display:"-webkit-box",WebkitLineClamp:2,WebkitBoxOrient:"vertical"}}>{b.name}</div>
                {b.author&&<div style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t2)",letterSpacing:".06em",marginBottom:7,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{b.author}</div>}
                <div style={{display:"flex",alignItems:"center",justifyContent:"space-between"}}>
                  <Tag cls={stc(b.status)}>{stl(b.status)}</Tag>
                  {tipC>0&&<span style={{fontFamily:"var(--fm)",fontSize:7.5,color:"var(--gold)",letterSpacing:".06em"}}>★ {tipC}</span>}
                </div>
              </div>
            </div>);})}
        </div>}
      <div style={{height:16}}/>
      <button onClick={()=>setSearchOpen(true)} style={{margin:"0 22px",width:"calc(100% - 44px)",padding:14,background:"var(--g1)",border:"1px solid var(--e0)",borderRadius:22,fontFamily:"var(--fm)",fontSize:9,letterSpacing:".16em",textTransform:"uppercase",color:"var(--t2)",cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",gap:8}}>
        <span style={{fontSize:16,lineHeight:1}}>+</span> Add New Book
      </button>
      {searchOpen&&<BookSearchSheet onClose={()=>setSearchOpen(false)} onBooked={data=>{setSearchOpen(false);setEditBook({...data,id:null});}} toast={toast}/>}
      {editBook!==null&&<BookEditSheet book={editBook} onClose={()=>setEditBook(null)} onSave={saveBook} onDelete={delBook}/>}
      {detail&&<BookDetailSheet book={books.find(b=>b.id===detail)} onClose={()=>setDetail(null)} onEdit={b=>{setDetail(null);setEditBook(b);}}/>}
    </div>
  );
}

/* ── BOOK SEARCH SHEET ───────────────────────────────── */
function BookSearchSheet({onClose,onBooked,toast}) {
  const [q,setQ]=useState("");
  const [sugg,setSugg]=useState([]);
  const [state,setState]=useState("idle"); // idle | searching | done | error
  const [sel,setSel]=useState(null);
  const [gen,setGen]=useState(false);
  const [steps,setSteps]=useState([]);
  const [err,setErr]=useState("");
  const [pending,setPending]=useState(null);
  const timer=useRef(null);
  const inp=useRef(null);

  const onInput=v=>{
    setQ(v);setSel(null);clearTimeout(timer.current);
    if(v.trim().length<2){setSugg([]);setState("idle");return;}
    setState("searching");setSugg([]);
    timer.current=setTimeout(async()=>{
      try{const r=await searchGoogleBooks(v.trim());setSugg(r);setState(r.length?"done":"error");}
      catch{setState("error");setSugg([]);}
    },400);
  };

  const pick=book=>{setSel(book);setQ(book.title);setSugg([]);setState("idle");};

  const generate=async(title,author)=>{
    if(!title.trim()){toast("Enter a book title first");return;}
    setErr("");setSteps([]);setGen(true);
    const lbls=["Identifying book","Writing overview","Extracting insights","Mapping chapters"];
    const cols=["var(--p)","var(--em)","var(--gold)","var(--sk)"];
    let si=0;const t=setInterval(()=>{if(si>=lbls.length){clearInterval(t);return;}setSteps(p=>[...p,{text:lbls[si],col:cols[si]}]);si++;},900);
    try{
      const res=await generateBookAI(title.trim(),author||"");
      clearInterval(t);
      onBooked({name:title.trim(),author:author||"",summary:res.summary||"",tips:(res.tips||[]).filter(x=>x.trim()),chapters:(res.chapters||[]).filter(c=>c.title||c.summary),status:"reading",isbn:sel?.isbn||"",thumbnail:sel?.thumbnail||"",color:sel?.color||""});
      toast("✨ AI summary ready — review & save");
    }catch(e){clearInterval(t);setErr(e.message||"Generation failed");setPending({title,author});setGen(false);}
  };

  const go=()=>sel?generate(sel.title,sel.author):generate(q,"");
  const showDrop=state==="searching"||(state==="done"&&sugg.length>0)||state==="error";

  return (<Sheet open onClose={onClose}>
    <ShDrag/><ShHdr title="ADD BOOK" sub="SEARCH BOOKS" onClose={onClose}/>
    <div style={C.shBody}>
      {!gen?<>
        {/* Input */}
        <label style={C.flabel}>Search for a book</label>
        <div style={{position:"relative",zIndex:10}}>
          <div style={{position:"absolute",left:14,top:"50%",transform:"translateY(-50%)",fontSize:16,pointerEvents:"none",zIndex:2}}>
            {state==="searching"?<span style={{display:"inline-block",animation:"spin .6s linear infinite",color:"var(--p)",fontSize:14}}>⟳</span>:"🔍"}
          </div>
          <input ref={inp} style={{...C.finput,paddingLeft:46,marginBottom:0,borderColor:showDrop?"rgba(124,110,248,.5)":"var(--e0)",borderBottomLeftRadius:showDrop?0:16,borderBottomRightRadius:showDrop?0:16}} value={q} onChange={e=>onInput(e.target.value)} onKeyDown={e=>{if(e.key==="Enter")go();if(e.key==="Escape"){setSugg([]);setState("idle");}}} placeholder="Title, author, or genre…" autoFocus/>

          {/* Dropdown */}
          {showDrop&&(
            <div style={{position:"absolute",top:"100%",left:0,right:0,background:"rgba(11,11,20,.98)",border:"1px solid rgba(124,110,248,.4)",borderTop:"none",borderRadius:"0 0 20px 20px",boxShadow:"0 20px 60px rgba(0,0,0,.8)",overflow:"hidden",maxHeight:380,overflowY:"auto"}}>
              {/* Skeleton */}
              {state==="searching"&&[0,1,2].map(i=>(
                <div key={i} style={{display:"flex",gap:12,padding:"12px 16px",borderBottom:"1px solid var(--e0)",opacity:1-i*.25}}>
                  <div style={{width:38,height:54,borderRadius:5,flexShrink:0,background:"linear-gradient(90deg,var(--g1) 25%,var(--g2) 50%,var(--g1) 75%)",backgroundSize:"200% 100%",animation:"shimmer 1.4s ease infinite",animationDelay:`${i*.15}s`}}/>
                  <div style={{flex:1,display:"flex",flexDirection:"column",gap:7,paddingTop:4}}>
                    <div style={{height:11,borderRadius:4,width:"70%",background:"linear-gradient(90deg,var(--g1) 25%,var(--g2) 50%,var(--g1) 75%)",backgroundSize:"200% 100%",animation:"shimmer 1.4s ease infinite",animationDelay:`${i*.1}s`}}/>
                    <div style={{height:8,borderRadius:4,width:"45%",background:"linear-gradient(90deg,var(--g1) 25%,var(--g2) 50%,var(--g1) 75%)",backgroundSize:"200% 100%",animation:"shimmer 1.4s ease infinite"}}/>
                    <div style={{height:8,borderRadius:4,width:"85%",background:"linear-gradient(90deg,var(--g1) 25%,var(--g2) 50%,var(--g1) 75%)",backgroundSize:"200% 100%",animation:"shimmer 1.4s ease infinite"}}/>
                  </div>
                </div>
              ))}
              {/* Results */}
              {sugg.map((b,i)=>(
                <div key={i} onClick={()=>pick(b)} style={{display:"flex",alignItems:"flex-start",gap:13,padding:"12px 16px",cursor:"pointer",borderBottom:i<sugg.length-1?"1px solid var(--e0)":"none",transition:"background .15s"}} onMouseEnter={e=>e.currentTarget.style.background="rgba(124,110,248,.08)"} onMouseLeave={e=>e.currentTarget.style.background="transparent"}>
                  <BookCover book={b} size={38}/>
                  <div style={{flex:1,minWidth:0,paddingTop:2}}>
                    <div style={{fontSize:13,fontWeight:700,color:"var(--t5)",marginBottom:3,lineHeight:1.3,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{b.title}</div>
                    <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:4,flexWrap:"wrap"}}>
                      <span style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t3)",letterSpacing:".04em"}}>{b.author}</span>
                      {b.year&&<span style={{fontFamily:"var(--fm)",fontSize:7,color:"var(--t1)"}}>· {b.year}</span>}
                      {b.genre&&<span style={{fontFamily:"var(--fm)",fontSize:6.5,color:genreCss(b.genre),background:`${genreCss(b.genre)}1a`,padding:"1px 6px",borderRadius:20,border:`1px solid ${genreCss(b.genre)}30`}}>{b.genre}</span>}
                    </div>
                    {b.desc&&<div style={{fontSize:11,color:"var(--t2)",lineHeight:1.5,display:"-webkit-box",WebkitLineClamp:2,WebkitBoxOrient:"vertical",overflow:"hidden"}}>{b.desc}</div>}
                  </div>
                  <div style={{color:"var(--p)",fontSize:15,opacity:.5,marginTop:6,flexShrink:0}}>›</div>
                </div>
              ))}
              {state==="error"&&<div style={{padding:"14px 18px",fontFamily:"var(--fm)",fontSize:9,color:"var(--t1)",letterSpacing:".1em",textAlign:"center"}}>No matches — try a different title</div>}
              {sugg.length>0&&<div style={{padding:"9px 18px",fontFamily:"var(--fm)",fontSize:7,color:"var(--t1)",letterSpacing:".12em",textAlign:"center",background:"rgba(124,110,248,.04)",borderTop:"1px solid var(--e0)"}}>TAP A BOOK → AI GENERATES FULL SUMMARY &amp; TIPS</div>}
            </div>
          )}
        </div>

        {/* Selected preview */}
        {sel&&(
          <div style={{display:"flex",alignItems:"center",gap:13,padding:"14px 16px",background:"rgba(124,110,248,.06)",border:"1px solid rgba(124,110,248,.25)",borderRadius:16,marginTop:14,animation:"fadeUp .3s ease"}}>
            <BookCover book={sel} size={46}/>
            <div style={{flex:1,minWidth:0}}>
              <div style={{fontSize:14,fontWeight:700,color:"var(--t5)",marginBottom:4,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{sel.title}</div>
              <div style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t3)",marginBottom:4}}>{sel.author}{sel.year?` · ${sel.year}`:""}</div>
              {sel.genre&&<span style={{fontFamily:"var(--fm)",fontSize:7,color:genreCss(sel.genre),background:`${genreCss(sel.genre)}1a`,padding:"2px 8px",borderRadius:20,border:`1px solid ${genreCss(sel.genre)}30`}}>{sel.genre}</span>}
            </div>
            <button onClick={()=>{setSel(null);setQ("");setTimeout(()=>inp.current?.focus(),80);}} style={{color:"var(--t2)",fontSize:20,background:"none",border:"none",cursor:"pointer",lineHeight:1,flexShrink:0}}>×</button>
          </div>
        )}

        {!sel&&state==="idle"&&<div style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t1)",letterSpacing:".1em",marginTop:12,marginBottom:4,lineHeight:1.6}}>Describe it, type a theme, author, or partial title — AI figures out the book</div>}

        {/* Generate button */}
        <button onClick={go} style={{...C.btnPri,marginTop:sel?16:12,marginBottom:14,fontSize:14,letterSpacing:".1em",opacity:q.trim()?1:.4,cursor:q.trim()?"pointer":"default"}}>
          <span style={{fontSize:15}}>✦</span>
          {sel?`GENERATE — "${sel.title.slice(0,26)}${sel.title.length>26?"…":""}"` : "GENERATE WITH AI"}
        </button>
        <div style={{borderTop:"1px solid var(--e0)",paddingTop:14}}>
          <button style={{...C.btnGhost,width:"100%",display:"flex",justifyContent:"center"}} onClick={()=>{onClose();onBooked({name:q||"",author:"",summary:"",tips:[],chapters:[],status:"reading"});}}>+ ADD MANUALLY</button>
        </div>

      </>:<>
        {/* Generating */}
        <div style={{padding:"36px 0",textAlign:"center"}}>
          {sel&&!err&&<div style={{display:"flex",justifyContent:"center",marginBottom:20}}><BookCover book={sel} size={64}/></div>}
          {!sel&&!err&&<div style={{width:44,height:44,margin:"0 auto 20px",borderRadius:"50%",border:"2px solid var(--e1)",borderTopColor:"var(--p)",animation:"spin .9s linear infinite"}}/>}
          {err&&<div style={{fontSize:36,marginBottom:16}}>⚠️</div>}
          <div style={{fontFamily:"var(--fd)",fontSize:17,letterSpacing:".06em",marginBottom:6,color:err?"var(--ro)":"var(--t5)"}}>
            {err?"Generation Failed":(sel?.title||q||"GENERATING…").slice(0,32)}
          </div>
          {!err&&<div style={{fontFamily:"var(--fm)",fontSize:9,color:"var(--t2)",letterSpacing:".1em"}}>Analyzing with AI…</div>}
          {err&&<div style={{fontFamily:"var(--fm)",fontSize:9,color:"var(--ro)",letterSpacing:".08em",margin:"8px auto 20px",lineHeight:1.5,maxWidth:280}}>{err}</div>}
          <div style={{display:"flex",flexDirection:"column",gap:8,textAlign:"left",maxWidth:260,margin:"20px auto 0"}}>
            {steps.map((st,i)=>(
              <div key={i} style={{display:"flex",alignItems:"center",gap:10,padding:"5px 0",animation:"stepIn .3s ease both",animationDelay:`${i*.08}s`}}>
                <div style={{width:7,height:7,borderRadius:"50%",background:st.col,flexShrink:0}}/>
                <span style={{fontFamily:"var(--fm)",fontSize:9,color:st.col,letterSpacing:".08em"}}>{st.text}</span>
                <span style={{marginLeft:"auto",fontSize:10,color:st.col}}>✓</span>
              </div>
            ))}
          </div>
          {err&&pending&&<div style={{display:"flex",gap:8,marginTop:20}}>
            <button onClick={()=>{setErr("");setSteps([]);setGen(true);generate(pending.title,pending.author);}} style={{flex:1,padding:11,background:"var(--p2)",border:"1px solid rgba(124,110,248,.3)",borderRadius:12,fontFamily:"var(--fm)",fontSize:9,color:"var(--p)",letterSpacing:".1em",cursor:"pointer"}}>↻ RETRY</button>
            <button onClick={()=>{onClose();onBooked({name:pending?.title||"",author:pending?.author||"",summary:"",tips:[],chapters:[],status:"reading"});}} style={{flex:1,padding:11,background:"var(--g1)",border:"1px solid var(--e1)",borderRadius:12,fontFamily:"var(--fm)",fontSize:9,color:"var(--t3)",letterSpacing:".1em",cursor:"pointer"}}>MANUAL →</button>
          </div>}
        </div>
      </>}
    </div>
  </Sheet>);
}

/* ── BOOK EDIT SHEET ─────────────────────────────────── */
function BookEditSheet({book,onClose,onSave,onDelete}) {
  const isNew=!book.id;
  const [name,setName]=useState(book.name||"");
  const [author,setAuthor]=useState(book.author||"");
  const [status,setStatus]=useState(book.status||"reading");
  const [summary,setSummary]=useState(book.summary||"");
  const [tips,setTips]=useState(book.tips?.length?[...book.tips]:[""] );
  const [chs,setChs]=useState(book.chapters?.length?book.chapters.map(c=>({...c})):[{title:"",summary:""}]);
  const save=()=>{if(!name.trim())return;onSave({...book,name:name.trim(),author:author.trim(),status,summary:summary.trim(),tips:tips.filter(t=>t.trim()),chapters:chs.filter(c=>c.title||c.summary)});};
  return (<Sheet open onClose={onClose} sx={{maxHeight:"96dvh"}}>
    <ShDrag/><ShHdr title={isNew?"NEW BOOK":"EDIT BOOK"} sub={isNew?"AI Generated — review & save":book.name} subColor="var(--em)" onClose={onClose}/>
    <div style={C.shBody}>
      <label style={C.flabel}>Book Title</label>
      <input style={C.finput} value={name} onChange={e=>setName(e.target.value)} placeholder="e.g. Atomic Habits" maxLength={80}/>
      <label style={C.flabel}>Author</label>
      <input style={C.finput} value={author} onChange={e=>setAuthor(e.target.value)} placeholder="e.g. James Clear" maxLength={60}/>
      <label style={C.flabel}>Status</label>
      <div style={{display:"flex",gap:7,marginBottom:18}}>
        {[["reading","Reading"],["done","Done"],["want","Want to Read"]].map(([v,l])=>(
          <button key={v} onClick={()=>setStatus(v)} style={{padding:"6px 16px",borderRadius:60,border:"1px solid var(--e0)",background:status===v?"var(--p2)":"var(--g1)",fontFamily:"var(--fm)",fontSize:9,color:status===v?"var(--p)":"var(--t2)",cursor:"pointer",boxShadow:status===v?"0 0 16px var(--p2)":"none"}}>{l}</button>
        ))}
      </div>
      <label style={C.flabel}>Summary</label>
      <textarea style={C.fta} rows={3} value={summary} onChange={e=>setSummary(e.target.value)} placeholder="What is this book about?"/>
      <label style={C.flabel}>Golden Tips</label>
      {tips.map((tip,i)=>(
        <div key={i} style={{background:"var(--g1)",border:"1px solid var(--e0)",borderRadius:16,padding:14,marginBottom:8}}>
          <div style={{display:"flex",justifyContent:"space-between",marginBottom:10}}>
            <span style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t2)",letterSpacing:".16em",textTransform:"uppercase"}}>Tip {i+1}</span>
            <button onClick={()=>setTips(t=>t.filter((_,j)=>j!==i).length?t.filter((_,j)=>j!==i):[""])} style={{color:"var(--ro)",fontSize:18,cursor:"pointer",background:"none",border:"none"}}>×</button>
          </div>
          <textarea style={{...C.fta,marginBottom:0,minHeight:60}} rows={2} value={tip} onChange={e=>setTips(t=>t.map((x,j)=>j===i?e.target.value:x))} placeholder="Enter golden tip…"/>
        </div>
      ))}
      <button onClick={()=>setTips(t=>[...t,""])} style={{width:"100%",padding:10,background:"none",border:"1px dashed var(--e1)",borderRadius:16,fontFamily:"var(--fm)",fontSize:8,letterSpacing:".14em",textTransform:"uppercase",color:"var(--t1)",cursor:"pointer",marginBottom:18}}>+ Add Golden Tip</button>
      <label style={C.flabel}>Chapters</label>
      {chs.map((ch,i)=>(
        <div key={i} style={{background:"var(--g1)",border:"1px solid var(--e0)",borderRadius:16,padding:14,marginBottom:8}}>
          <div style={{display:"flex",justifyContent:"space-between",marginBottom:10}}>
            <span style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t2)",letterSpacing:".16em",textTransform:"uppercase"}}>Chapter {i+1}</span>
            <button onClick={()=>setChs(c=>c.filter((_,j)=>j!==i).length?c.filter((_,j)=>j!==i):[{title:"",summary:""}])} style={{color:"var(--ro)",fontSize:18,cursor:"pointer",background:"none",border:"none"}}>×</button>
          </div>
          <input style={{...C.finput,marginBottom:10}} value={ch.title||""} onChange={e=>setChs(c=>c.map((x,j)=>j===i?{...x,title:e.target.value}:x))} placeholder="Chapter title…"/>
          <textarea style={{...C.fta,marginBottom:0,minHeight:70}} rows={3} value={ch.summary||""} onChange={e=>setChs(c=>c.map((x,j)=>j===i?{...x,summary:e.target.value}:x))} placeholder="Chapter summary…"/>
        </div>
      ))}
      <button onClick={()=>setChs(c=>[...c,{title:"",summary:""}])} style={{width:"100%",padding:10,background:"none",border:"1px dashed var(--e1)",borderRadius:16,fontFamily:"var(--fm)",fontSize:8,letterSpacing:".14em",textTransform:"uppercase",color:"var(--t1)",cursor:"pointer",marginBottom:18}}>+ Add Chapter</button>
      <div style={{display:"flex",gap:10}}>
        <button style={{...C.btnPri,flex:1}} onClick={save}>SAVE BOOK</button>
        {!isNew&&<button style={C.btnDng} onClick={()=>onDelete(book.id)}>DELETE</button>}
      </div>
    </div>
  </Sheet>);
}

/* ── BOOK DETAIL SHEET ───────────────────────────────── */
function BookDetailSheet({book,onClose,onEdit}) {
  const [tab,setTab]=useState("overview");
  if(!book)return null;
  const col=book.color||BOOK_COLORS[(book.id-1)%BOOK_COLORS.length];
  const tips=(book.tips||[]).filter(t=>t),chs=(book.chapters||[]).filter(c=>c.title||c.summary);
  const stl=s=>s==="reading"?"Reading":s==="done"?"Done":"Want to Read",stc=s=>s==="reading"?"sk":s==="done"?"em":"p";
  return (<Sheet open onClose={onClose} sx={{maxHeight:"96dvh",borderTopColor:col,boxShadow:`0 -8px 70px rgba(0,0,0,.75),0 0 0 1px ${col}44`}}>
    <ShDrag/>
    <div style={{padding:"20px 22px 16px",display:"flex",gap:16,alignItems:"flex-end",borderBottom:"1px solid rgba(255,255,255,.06)",background:`linear-gradient(160deg,${col}0d 0%,transparent 50%)`,position:"relative"}}>
      <div style={{position:"absolute",left:14,top:14,width:80,height:112,background:col,opacity:.06,filter:"blur(24px)",borderRadius:8,pointerEvents:"none"}}/>
      <div style={{position:"relative",zIndex:1}}><BookCover book={{...book,title:book.name}} size={72}/></div>
      <div style={{flex:1,minWidth:0,position:"relative",zIndex:1}}>
        <div style={{fontFamily:"var(--fd)",fontSize:20,fontWeight:800,color:"var(--t6)",letterSpacing:".02em",lineHeight:1.1,marginBottom:5}}>{book.name}</div>
        {book.author&&<div style={{fontFamily:"var(--fm)",fontSize:9,color:"var(--t2)",letterSpacing:".1em",marginBottom:8}}>{book.author}</div>}
        <div style={{display:"flex",gap:6,alignItems:"center"}}>
          <Tag cls={stc(book.status)}>{stl(book.status)}</Tag>
          <button onClick={()=>onEdit(book)} style={{background:"none",border:"1px solid var(--e0)",borderRadius:20,cursor:"pointer",fontFamily:"var(--fm)",fontSize:8,color:"var(--t2)",padding:"3px 8px",letterSpacing:".1em",textTransform:"uppercase"}}>EDIT</button>
        </div>
      </div>
    </div>
    <div style={{display:"flex",gap:2,padding:"0 22px"}}>
      {[["overview","Overview"],["tips","Golden Tips"],["chapters","Chapters"]].map(([t,l])=>(
        <button key={t} onClick={()=>setTab(t)} style={{flex:1,padding:"12px 8px",fontFamily:"var(--fm)",fontSize:8,letterSpacing:".14em",textTransform:"uppercase",color:tab===t?"var(--t5)":"var(--t2)",cursor:"pointer",background:"none",border:"none",position:"relative",transition:"color .22s ease"}}>
          {l}
          {tab===t&&<div style={{position:"absolute",bottom:0,left:"20%",right:"20%",height:2,borderRadius:2,background:"linear-gradient(to right,var(--p),#a78bfa)",animation:"tabSlide .22s cubic-bezier(.22,1,.36,1)"}}/>}
        </button>
      ))}
    </div>
    {tab==="overview"&&<div style={{padding:"18px 22px"}}>
      <Lbl style={{marginBottom:12}}>Summary</Lbl>
      <div style={{fontSize:14,color:book.summary?"var(--t4)":"var(--t1)",lineHeight:1.75}}>{book.summary||"No summary yet."}</div>
      <div style={{height:20}}/>
      <Lbl style={{marginBottom:12}}>Quick Stats</Lbl>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
        {[{l:"Tips",v:tips.length,c:"var(--gold)"},{l:"Chapters",v:chs.length,c:"var(--p)"}].map(({l,v,c})=>(
          <div key={l} style={{background:"var(--g1)",border:"1px solid var(--e0)",borderRadius:22,padding:"12px 14px 10px",position:"relative",overflow:"hidden",color:c}}>
            <div style={{position:"absolute",top:0,left:12,right:12,height:1.5,background:"currentColor",opacity:.4,borderRadius:"0 0 4px 4px"}}/>
            <div style={{fontFamily:"var(--fd)",fontSize:24,fontWeight:800,lineHeight:1}}>{v||"—"}</div>
            <div style={{fontFamily:"var(--fm)",fontSize:7,letterSpacing:".16em",textTransform:"uppercase",color:"var(--t1)",marginTop:8}}>{l}</div>
          </div>
        ))}
      </div>
    </div>}
    {tab==="tips"&&<div style={{padding:"18px 22px"}}>
      {tips.length===0?<div style={{padding:"32px 0",textAlign:"center",fontFamily:"var(--fm)",fontSize:10,color:"var(--t1)",letterSpacing:".12em"}}>No golden tips yet</div>:tips.map((tip,i)=>(
        <div key={i} style={{background:"linear-gradient(145deg,rgba(228,184,74,.06),rgba(228,184,74,.02))",border:"1px solid rgba(228,184,74,.15)",borderRadius:16,padding:"14px 16px",marginBottom:8,display:"flex",gap:12,alignItems:"flex-start",boxShadow:"0 2px 12px rgba(0,0,0,.3)"}}>
          <div style={{fontFamily:"var(--fd)",fontSize:18,fontWeight:800,color:"var(--gold)",lineHeight:1,flexShrink:0,minWidth:24,textShadow:"0 0 20px rgba(228,184,74,.4)"}}>{i+1}</div>
          <div style={{fontSize:13,color:"var(--t4)",lineHeight:1.7}}>{tip}</div>
        </div>
      ))}
    </div>}
    {tab==="chapters"&&<div style={{padding:"18px 22px"}}>
      {chs.length===0?<div style={{padding:"32px 0",textAlign:"center",fontFamily:"var(--fm)",fontSize:10,color:"var(--t1)",letterSpacing:".12em"}}>No chapters yet</div>:chs.map((ch,i)=>(
        <div key={i} style={{padding:"14px 0",borderBottom:"1px solid var(--e0)"}}>
          <div style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t2)",letterSpacing:".14em",textTransform:"uppercase",marginBottom:4}}>Chapter {i+1}</div>
          <div style={{fontSize:14,fontWeight:600,color:"var(--t5)",marginBottom:4}}>{ch.title||"Untitled"}</div>
          {ch.summary&&<div style={{fontSize:12,color:"var(--t3)",lineHeight:1.6}}>{ch.summary}</div>}
        </div>
      ))}
    </div>}
  </Sheet>);
}

/* ════════════════════════════════════════════════════
   SYNC SHEET
════════════════════════════════════════════════════ */
function SyncSheet({habits,open,onClose,toast}) {
  const [dur,setDur]=useState(60);
  const [dates,setDates]=useState({});
  const [times,setTimes]=useState({});
  const [sent,setSent]=useState({});
  const nn=habits.filter(h=>h.isNN),td=today();
  const hasGoogleCreds = ()=>!!(localStorage.getItem("vg_google_api_key") && localStorage.getItem("vg_google_client_id"));
  const syncOne=async id=>{const h=habits.find(x=>x.id===id);if(!h)return;if(hasGoogleCreds()){try{await createGoogleCalendarEvent(h.name,dates[id]||td,times[id]||h.time,dur);setSent(s=>({...s,[id]:true}));toast(`✓ "${h.name}" → Google Calendar`);return;}catch(e){toast("Google Calendar error — downloading .ics");console.error(e);}}openCalendarEvent(h.name,dates[id]||td,times[id]||h.time,dur);setSent(s=>({...s,[id]:true}));toast(`${pfI()} "${h.name}" → ${pfL()}`);};
  const syncAll=async()=>{for(const h of nn){await syncOne(h.id);await new Promise(r=>setTimeout(r,700));}toast(`✓ ${nn.length} events synced`);setTimeout(onClose,900);};
  return (<Sheet open={open} onClose={onClose}>
    <ShDrag/><ShHdr title="SYNC TO CALENDAR" sub={pfL()} onClose={onClose}/>
    <div style={C.shBody}>
      <div style={{background:"linear-gradient(135deg,rgba(45,212,160,.15),rgba(45,212,160,.08))",border:"1px solid rgba(45,212,160,.28)",borderRadius:16,padding:"10px 16px",marginBottom:20,display:"flex",alignItems:"center",gap:10}}>
        <div style={{width:7,height:7,borderRadius:"50%",background:"var(--em)",boxShadow:"0 0 10px var(--em)",animation:"breathe 2.4s ease-in-out infinite",flexShrink:0}}/>
        <span style={{fontFamily:"var(--fm)",fontSize:9,color:"var(--em)",letterSpacing:".18em",textTransform:"uppercase"}}>CONNECTED · {nn.length} NON-NEGOTIABLES READY</span>
      </div>
      <label style={C.flabel}>Block Duration</label>
      <div style={{display:"flex",gap:7,marginBottom:6}}>
        {[30,60,90,120].map(d=><button key={d} onClick={()=>setDur(d)} style={{padding:"6px 16px",borderRadius:60,border:"1px solid var(--e0)",background:dur===d?"var(--p2)":"var(--g1)",fontFamily:"var(--fm)",fontSize:9,color:dur===d?"var(--p)":"var(--t2)",cursor:"pointer",boxShadow:dur===d?"0 0 0 1px rgba(124,110,248,.3),0 0 20px rgba(124,110,248,.18)":"none",transition:"all .22s ease"}}>{d}m</button>)}
      </div>
      <div style={{marginTop:20}}>
        {nn.map(h=>(
          <div key={h.id} style={{padding:"18px 0",borderBottom:"1px solid var(--e0)",display:"grid",gridTemplateColumns:"1fr auto",alignItems:"start",gap:14}}>
            <div>
              <div style={{fontSize:15,fontWeight:600,color:"var(--t5)",marginBottom:11,display:"flex",alignItems:"center",gap:9}}>{sent[h.id]&&<span style={{color:"var(--em)"}}>✓</span>}{h.name}<Tag cls="em">NN</Tag></div>
              <div style={{display:"flex",flexDirection:"column",gap:9}}>
                <div style={{display:"flex",alignItems:"center",gap:9}}>
                  <span style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t2)",letterSpacing:".18em",textTransform:"uppercase",minWidth:34}}>DATE</span>
                  <input type="date" value={dates[h.id]||td} onChange={e=>setDates(d=>({...d,[h.id]:e.target.value}))} style={{padding:"8px 12px",background:"rgba(124,110,248,.08)",border:"1px solid rgba(124,110,248,.18)",borderRadius:10,color:"var(--p)",fontFamily:"var(--fm)",fontSize:11,minWidth:128}}/>
                </div>
                <div style={{display:"flex",alignItems:"center",gap:9}}>
                  <span style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t2)",letterSpacing:".18em",textTransform:"uppercase",minWidth:34}}>TIME</span>
                  <input type="time" value={times[h.id]||h.time} onChange={e=>setTimes(t=>({...t,[h.id]:e.target.value}))} style={{padding:"8px 12px",background:"rgba(124,110,248,.08)",border:"1px solid rgba(124,110,248,.18)",borderRadius:10,color:"var(--p)",fontFamily:"var(--fm)",fontSize:11,minWidth:78}}/>
                  <span style={{fontFamily:"var(--fm)",fontSize:10,color:"var(--t1)"}}>→ {endT(times[h.id]||h.time,dur)}</span>
                </div>
              </div>
            </div>
            <div style={{paddingTop:4}}>
              <button onClick={()=>syncOne(h.id)} style={{padding:"10px 16px",background:sent[h.id]?"var(--em1)":"var(--g1)",border:`1px solid ${sent[h.id]?"rgba(45,212,160,.3)":"var(--e0)"}`,borderRadius:10,color:sent[h.id]?"var(--em)":"var(--t2)",fontFamily:"var(--fm)",fontSize:8,letterSpacing:".12em",textTransform:"uppercase",cursor:"pointer",whiteSpace:"nowrap"}}>{sent[h.id]?"✓ SENT":"SYNC →"}</button>
            </div>
          </div>
        ))}
      </div>
      <div style={{marginTop:24}}>
        <button className="btn-shine btn-lift" style={C.btnPri} onClick={syncAll}>SYNC ALL EVENTS</button>
        <p style={{textAlign:"center",fontFamily:"var(--fm)",fontSize:8,color:"var(--t0)",letterSpacing:".1em",textTransform:"uppercase",marginTop:12}}>Opens in your calendar app for confirmation</p>
      </div>
    </div>
  </Sheet>);
}

/* ════════════════════════════════════════════════════
   PROFILE SCREEN
════════════════════════════════════════════════════ */
function FilledField({label,storageKey,placeholder,onSave,type="text",hint}) {
  const inp={width:"100%",padding:"13px 16px",background:"rgba(255,255,255,.04)",border:"1px solid rgba(255,255,255,.06)",borderRadius:16,color:"var(--t6)",fontFamily:"var(--fb)",fontSize:15,fontWeight:500,caretColor:"var(--p)",display:"block",boxSizing:"border-box"};
  const [editing,setEditing]=useState(false);
  const [val,setVal]=useState("");
  const [stored,setStored]=useState(!!localStorage.getItem(storageKey));
  const save=()=>{
    if(!val.trim())return;
    localStorage.setItem(storageKey,val.trim());
    if(onSave)onSave(val.trim());
    setEditing(false);setVal("");setStored(true);
  };
  return (
    <div style={{marginBottom:16}}>
      <div style={{fontFamily:"var(--fm)",fontSize:8,color:"var(--t1)",letterSpacing:".18em",textTransform:"uppercase",marginBottom:7}}>{label}</div>
      {stored&&!editing?(
        <div style={{position:"relative"}}>
          <input readOnly value="Already filled" style={{...inp,color:"var(--t2)",cursor:"default",paddingRight:96}}/>
          <button onClick={()=>setEditing(true)} style={{position:"absolute",right:10,top:"50%",transform:"translateY(-50%)",padding:"5px 13px",background:"rgba(124,110,248,.12)",border:"1px solid rgba(124,110,248,.25)",borderRadius:8,color:"var(--p)",fontFamily:"var(--fm)",fontSize:8,letterSpacing:".1em",textTransform:"uppercase",cursor:"pointer"}}>Change</button>
        </div>
      ):(
        <div style={{display:"flex",gap:8,alignItems:"center"}}>
          <input value={val} onChange={e=>setVal(e.target.value)} onKeyDown={e=>e.key==="Enter"&&save()} placeholder={placeholder} style={{...inp,flex:1}} type={type} autoFocus={editing}/>
          <button onClick={save} style={{padding:"13px 16px",background:"rgba(255,255,255,.04)",border:"1px solid rgba(255,255,255,.08)",borderRadius:10,fontFamily:"var(--fm)",fontSize:9,letterSpacing:".14em",textTransform:"uppercase",color:"var(--t2)",cursor:"pointer",flexShrink:0}}>Save</button>
          {editing&&<button onClick={()=>{setEditing(false);setVal("");}} style={{padding:"13px 10px",background:"none",border:"none",color:"var(--ro)",fontSize:18,cursor:"pointer",flexShrink:0}}>×</button>}
        </div>
      )}
      {hint&&<div style={{fontSize:10,color:"var(--t1)",lineHeight:1.55,marginTop:7}}>{hint}</div>}
    </div>
  );
}

